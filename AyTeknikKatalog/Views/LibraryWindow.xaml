<Window x:Class="AyTeknikKatalog.Views.LibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AyTeknikKatalog.Converters"
        xmlns:m="clr-namespace:AyTeknikKatalog.Models"
        Width="760" Height="640"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="{StaticResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

    <Window.Resources>
        <conv:CountToVisibilityConverter x:Key="CountToVisibility" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibility" />
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.16" BlurRadius="24" ShadowDepth="2" Direction="270" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Height="48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="Transparent" MouseLeftButtonDown="OnDragMove">
                    <TextBlock Text="Kütüphane" Style="{StaticResource DisplayText}"
                               FontSize="14" Margin="22,0,0,0" VerticalAlignment="Center" />
                </Border>
                <Button Grid.Column="1" Style="{StaticResource IconButton}" Width="32" Height="32"
                        Margin="0,8,12,0" Click="OnClose" ToolTip="Kapat" IsCancel="True">
                    <Path Data="M18 6 6 18 M6 6l12 12" Width="14" Height="14" Stretch="Uniform"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.6" Fill="Transparent" />
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" Margin="22,0,22,16">
                <TextBlock Text="Üretilmiş Kataloglar" Style="{StaticResource DisplayText}" FontSize="20" />
                <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,0">
                    <Run Text="{Binding Entries.Count, Mode=OneWay}" />
                    <Run Text=" katalog · En yeniden eskiye sıralı · 'Düzenle' ile editöre yükle, 'Önizle' ile aç" />
                </TextBlock>
            </StackPanel>

            <Grid Grid.Row="2" Margin="22,0,22,16">
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="48"
                        Visibility="{Binding Entries.Count, Converter={StaticResource CountToVisibility}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Data="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8"
                              Width="40" Height="40" Stretch="Uniform"
                              Stroke="{StaticResource MutedBrush}" StrokeThickness="1.5" Fill="Transparent" />
                        <TextBlock Text="Henüz hiç PDF üretilmedi" Style="{StaticResource BodyText}"
                                   FontWeight="SemiBold" Margin="0,16,0,4" HorizontalAlignment="Center" />
                        <TextBlock Text="Editöre dönün, katalog hazırlayıp 'PDF Üret' ile bir kayıt oluşturun."
                                   Style="{StaticResource MutedText}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding Entries.Count, Converter={StaticResource CountToVisibility}, ConverterParameter=Inverted}">
                    <ItemsControl ItemsSource="{Binding Entries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type m:CatalogEntry}">
                                <Border Margin="0,0,0,8" Background="{StaticResource BackgroundBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8"
                                        Padding="16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayTitle}" Style="{StaticResource BodyText}"
                                                       FontWeight="SemiBold" FontSize="14"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding DisplaySubtitle}" Style="{StaticResource MutedText}"
                                                       FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding DisplaySubtitle, Converter={StaticResource NullToVisibility}}" />
                                            <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,0">
                                                <Run Text="{Binding CreatedAt, StringFormat='dd MMM yyyy HH:mm', Mode=OneWay}" />
                                                <Run Text=" · " />
                                                <Run Text="{Binding ProductCount, Mode=OneWay}" />
                                                <Run Text=" ürün · " />
                                                <Run Text="{Binding ReferenceCount, Mode=OneWay}" />
                                                <Run Text=" referans" />
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Style="{StaticResource SecondaryButton}" Content="Önizle"
                                                    Margin="0,0,8,0" Click="OnPreview" Tag="{Binding}" />
                                            <Button Style="{StaticResource SecondaryButton}" Content="Düzenle"
                                                    Margin="0,0,8,0" Click="OnLoad" Tag="{Binding}" />
                                            <Button Style="{StaticResource IconButton}" Width="36" Height="36"
                                                    Margin="0,0,4,0" Click="OnRename" Tag="{Binding}" ToolTip="Yeniden Adlandır">
                                                <Path Data="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z M15 5l4 4"
                                                      Width="14" Height="14" Stretch="Uniform"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      StrokeThickness="1.6" Fill="Transparent" />
                                            </Button>
                                            <ToggleButton x:Name="ShareToggle" Width="36" Height="36" Margin="0,0,4,0"
                                                          Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                          ToolTip="Paylaş">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border x:Name="Bd" CornerRadius="6" Background="{TemplateBinding Background}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceBrush}" />
                                                            </Trigger>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceBrush}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                                <Path Data="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8 M16 6l-4-4-4 4 M12 2v13"
                                                      Width="16" Height="16" Stretch="Uniform"
                                                      Stroke="{StaticResource MutedBrush}"
                                                      StrokeThickness="1.6" Fill="Transparent" StrokeLineJoin="Round" />
                                            </ToggleButton>
                                            <Popup IsOpen="{Binding IsChecked, ElementName=ShareToggle, Mode=TwoWay}"
                                                   PlacementTarget="{Binding ElementName=ShareToggle}"
                                                   Placement="Bottom" VerticalOffset="6" HorizontalOffset="-180"
                                                   StaysOpen="False" AllowsTransparency="True"
                                                   PopupAnimation="Fade">
                                                <Border Background="{StaticResource BackgroundBrush}"
                                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                        CornerRadius="10" Padding="6" Width="220" Margin="6">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="Black" Opacity="0.18" BlurRadius="20" ShadowDepth="2" />
                                                    </Border.Effect>
                                                    <StackPanel>
                                                        <Button Style="{StaticResource ShareMenuItem}" Click="OnShareEmail" Tag="{Binding}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Path Data="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z M22 6 12 13 2 6"
                                                                      Width="16" Height="16" Stretch="Uniform"
                                                                      Stroke="{StaticResource TextBrush}" StrokeThickness="1.6"
                                                                      Fill="Transparent" StrokeLineJoin="Round"
                                                                      VerticalAlignment="Center" />
                                                                <TextBlock Text="E-posta ile gönder" Margin="12,0,0,0"
                                                                           VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Button>
                                                        <Button Style="{StaticResource ShareMenuItem}" Click="OnShareWhatsApp" Tag="{Binding}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Path Data="M20.52 3.48A12 12 0 0 0 3.5 20.5L2 22l1.6-4.3A12 12 0 1 0 20.52 3.48z M9 9.5c.5 1 1.5 2 3 3s2.5 1.5 3 1.5l1-1 3 1.5v3c0 .5-.5 1-1 1-7 0-13-6-13-13 0-.5.5-1 1-1h3l1.5 3z"
                                                                      Width="16" Height="16" Stretch="Uniform"
                                                                      Fill="#25D366" Stroke="#25D366" StrokeThickness="0.5"
                                                                      VerticalAlignment="Center" />
                                                                <TextBlock Text="WhatsApp" Margin="12,0,0,0"
                                                                           VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Button>
                                                        <Button Style="{StaticResource ShareMenuItem}" Click="OnShareInstagram" Tag="{Binding}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Path Data="M5 2h14a3 3 0 0 1 3 3v14a3 3 0 0 1-3 3H5a3 3 0 0 1-3-3V5a3 3 0 0 1 3-3z M16 11.5a4 4 0 1 1-8 0 4 4 0 0 1 8 0z M17.5 6.5h.01"
                                                                      Width="16" Height="16" Stretch="Uniform"
                                                                      Stroke="#E4405F" StrokeThickness="1.6"
                                                                      Fill="Transparent" StrokeLineJoin="Round"
                                                                      VerticalAlignment="Center" />
                                                                <TextBlock Text="Instagram" Margin="12,0,0,0"
                                                                           VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Button>
                                                        <Button Style="{StaticResource ShareMenuItem}" Click="OnShareTelegram" Tag="{Binding}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Path Data="M21.5 2.5 2 11l6 2 2 6 3.5-4 6 5z M10 13l11-10"
                                                                      Width="16" Height="16" Stretch="Uniform"
                                                                      Stroke="#0088cc" StrokeThickness="1.6"
                                                                      Fill="Transparent" StrokeLineJoin="Round"
                                                                      VerticalAlignment="Center" />
                                                                <TextBlock Text="Telegram" Margin="12,0,0,0"
                                                                           VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Button>
                                                        <Button Style="{StaticResource ShareMenuItem}" Click="OnShareLinkedIn" Tag="{Binding}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Path Data="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z M2 9h4v12H2z M4 6a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"
                                                                      Width="16" Height="16" Stretch="Uniform"
                                                                      Stroke="#0A66C2" StrokeThickness="1.6"
                                                                      Fill="Transparent" StrokeLineJoin="Round"
                                                                      VerticalAlignment="Center" />
                                                                <TextBlock Text="LinkedIn" Margin="12,0,0,0"
                                                                           VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Button>
                                                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="6,4" />
                                                        <Button Style="{StaticResource ShareMenuItem}" Click="OnCopyFile" Tag="{Binding}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Path Data="M9 9V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-4 M5 9h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2z"
                                                                      Width="16" Height="16" Stretch="Uniform"
                                                                      Stroke="{StaticResource TextBrush}" StrokeThickness="1.6"
                                                                      Fill="Transparent" StrokeLineJoin="Round"
                                                                      VerticalAlignment="Center" />
                                                                <TextBlock Text="Dosyayı kopyala" Margin="12,0,0,0"
                                                                           VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Button>
                                                        <Button Style="{StaticResource ShareMenuItem}" Click="OnShowInExplorer" Tag="{Binding}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Path Data="M3 7a2 2 0 0 1 2-2h4l2 2.5h8a2 2 0 0 1 2 2V18a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
                                                                      Width="16" Height="16" Stretch="Uniform"
                                                                      Stroke="{StaticResource TextBrush}" StrokeThickness="1.6"
                                                                      Fill="Transparent" StrokeLineJoin="Round"
                                                                      VerticalAlignment="Center" />
                                                                <TextBlock Text="Klasörde göster" Margin="12,0,0,0"
                                                                           VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>
                                                </Border>
                                            </Popup>
                                            <Button Style="{StaticResource DangerIconButton}" Width="36" Height="36"
                                                    Click="OnDelete" Tag="{Binding}" ToolTip="Sil">
                                                <Path Data="M3 6h18 M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2 M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6 M10 11v6 M14 11v6"
                                                      Width="14" Height="14" Stretch="Uniform"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      StrokeThickness="1.6" Fill="Transparent" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>

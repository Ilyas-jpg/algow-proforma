<Window x:Class="AyTeknikKatalog.Views.ReferenceEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AyTeknikKatalog.Converters"
        Width="500" Height="480"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="{StaticResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

    <Window.Resources>
        <conv:PathToImageConverter x:Key="PathToImage" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibility" />
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.16" BlurRadius="24" ShadowDepth="2" Direction="270" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Height="48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="Transparent" MouseLeftButtonDown="OnDragMove">
                    <TextBlock x:Name="TitleText" Style="{StaticResource DisplayText}"
                               FontSize="14" Margin="22,0,0,0" VerticalAlignment="Center" />
                </Border>
                <Button Grid.Column="1" Style="{StaticResource IconButton}" Width="32" Height="32"
                        Margin="0,8,12,0" Click="OnCancel" ToolTip="Kapat">
                    <Path Data="M18 6 6 18 M6 6l12 12" Width="14" Height="14" Stretch="Uniform"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.6" Fill="Transparent" />
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" Margin="22,4,22,16">
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Height="160" Margin="0,8,0,0">
                    <Grid>
                        <Image Source="{Binding LogoPath, Converter={StaticResource PathToImage}}"
                               Stretch="Uniform" Margin="20"
                               Visibility="{Binding LogoPath, Converter={StaticResource NullToVisibility}}" />
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding LogoPath, Converter={StaticResource NullToVisibility}, ConverterParameter=Inverted}">
                            <Path Data="M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z M9 9a2 2 0 1 1 0-4 2 2 0 0 1 0 4z M21 15l-5-5L5 21"
                                  Width="28" Height="28" Stretch="Uniform"
                                  Stroke="{StaticResource MutedBrush}" StrokeThickness="1.5" Fill="Transparent" />
                            <TextBlock Text="Firma logosu eklenmedi" Style="{StaticResource MutedText}"
                                       Margin="0,8,0,0" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Button Style="{StaticResource SecondaryButton}" Content="Logo Seç"
                        Margin="0,12,0,0" HorizontalAlignment="Stretch" Click="OnBrowseLogo" />

                <TextBlock Text="Firma Adı (opsiyonel)" Style="{StaticResource LabelText}" Margin="0,20,0,6" />
                <TextBox Style="{StaticResource ModernTextBox}"
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="22,16">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource SecondaryButton}" Content="İptal"
                            Margin="0,0,8,0" Click="OnCancel" IsCancel="True" />
                    <Button x:Name="SaveBtn" Style="{StaticResource PrimaryButton}" Content="Kaydet"
                            Click="OnSave" IsDefault="True" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>

                                    <ComboBox SelectedValue="{Binding Catalog.Cover.CustomCoverImageMode}"
                                              SelectedValuePath="Tag" Margin="0,0,0,12">
                                        <ComboBoxItem Content="Tam sayfa — görsel A4'ün tamamı, üstüne marka paneli" Tag="{x:Static m:CoverImageMode.FullPage}" />
                                        <ComboBoxItem Content="Üst yarı foto + alt yarı marka şeridi (logo, başlık, iletişim)" Tag="{x:Static m:CoverImageMode.TopWithBrandBar}" />
                                        <ComboBoxItem Content="Sağ yarı foto + sol yarı tipografi (başlık, slogan, year)" Tag="{x:Static m:CoverImageMode.BackgroundWithOverlay}" />
                                    </ComboBox>
                                    <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="6" Height="180"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <Grid>
                                            <Image Source="{Binding Catalog.Cover.CustomCoverImagePath, Converter={StaticResource PathToImage}}"
                                                   Stretch="Uniform" Margin="14"
                                                   Visibility="{Binding Catalog.Cover.CustomCoverImagePath, Converter={StaticResource NullToVisibility}}" />
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Visibility="{Binding Catalog.Cover.CustomCoverImagePath, Converter={StaticResource NullToVisibility}, ConverterParameter=Inverted}">
                                                <Path Data="M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z M9 9a2 2 0 1 1 0-4 2 2 0 0 1 0 4z M21 15l-5-5L5 21"
                                                      Width="32" Height="32" Stretch="Uniform"
                                                      Stroke="{DynamicResource MutedBrush}" StrokeThickness="1.5" Fill="Transparent" />
                                                <TextBlock Text="Henüz özel kapak yüklenmedi" Style="{StaticResource MutedText}"
                                                           Margin="0,12,0,0" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Button Style="{StaticResource SecondaryButton}" Content="Kapak Görseli Yükle"
                                                Margin="0,0,8,0" Command="{Binding BrowseCoverImageCommand}" />
                                        <Button Style="{StaticResource SecondaryButton}" Content="Kaldır"
                                                Command="{Binding ClearCoverImageCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Ana Başlık (boşsa marka adı kullanılır)" Style="{StaticResource LabelText}" />
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Catalog.Cover.MainTitle, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="Alt Başlık" Style="{StaticResource LabelText}" Margin="0,16,0,6" />
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Catalog.Cover.Subtitle, UpdateSourceTrigger=PropertyChanged}" />

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="2*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Yıl (boşsa içinde bulunulan yıl)" Style="{StaticResource LabelText}" />
                                    <TextBox Style="{StaticResource ModernTextBox}"
                                             Text="{Binding Catalog.Cover.YearText, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Bölüm Başlığı" Style="{StaticResource LabelText}" />
                                    <TextBox Style="{StaticResource ModernTextBox}"
                                             Text="{Binding Catalog.Cover.SectionLabel, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Tarih (boşsa yıl gösterilir, doluysa onun yerine basılır — örn: Mayıs 2026)" Style="{StaticResource LabelText}" Margin="0,16,0,6" />
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Catalog.Cover.DateText, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="Hakkımızda Metni" Style="{StaticResource LabelText}" Margin="0,24,0,6" />
                            <CheckBox Style="{StaticResource ModernCheckBox}"
                                      Content="Hakkımızda metnini kapakta göster"
                                      IsChecked="{Binding Catalog.Cover.ShowAbout}" />

                            <CheckBox Style="{StaticResource ModernCheckBox}" Margin="0,16,0,0"
                                      Content="İletişim şeridini göster (telefon · e-posta · web · adres)"
                                      IsChecked="{Binding Catalog.Cover.ShowContactBar}" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" TextElement.FontFamily="{StaticResource BodyFont}"
                                TextElement.FontSize="13" TextElement.FontWeight="SemiBold">
                        <TextBlock Text="Referanslar" />
                        <TextBlock Text="{Binding Catalog.References.Count, StringFormat=' ({0})'}"
                                   Foreground="{DynamicResource MutedBrush}" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="0,16,0,32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Referanslar" Style="{StaticResource DisplayText}" FontSize="22" />
                            <TextBlock Text="İş ortakları ve değerli müşteriler — kapak sonrası sayfada listelenir."
                                       Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox Style="{StaticResource ModernCheckBox}"
                                      Content="Referans sayfası istemiyorum" VerticalAlignment="Center" Margin="0,0,12,0"
                                      IsChecked="{Binding Catalog.SkipReferencesPage}"
                                      ToolTip="İşaretliyse üretilen PDF'e referans sayfası eklenmez." />
                            <Button Style="{StaticResource PrimaryButton}" Content="Referans Ekle"
                                    Command="{Binding AddReferenceCommand}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,28,0,0">
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="48"
                                Visibility="{Binding Catalog.References.Count, Converter={StaticResource CountToVisibility}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path Data="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2 M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2 M10 6h4 M10 10h4 M10 14h4 M10 18h4"
                                      Width="40" Height="40" Stretch="Uniform"
                                      Stroke="{DynamicResource MutedBrush}" StrokeThickness="1.5" Fill="Transparent" />
                                <TextBlock Text="Henüz referans eklenmedi" Style="{StaticResource BodyText}"
                                           FontWeight="SemiBold" Margin="0,16,0,4" HorizontalAlignment="Center" />
                                <TextBlock Text="Yukarıdan 'Referans Ekle' ile firma logosu ve adı ekleyin."
                                           Style="{StaticResource MutedText}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding Catalog.References.Count, Converter={StaticResource CountToVisibility}, ConverterParameter=Inverted}">
                            <ItemsControl ItemsSource="{Binding Catalog.References}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="4" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" TextElement.FontFamily="{StaticResource BodyFont}"
                                TextElement.FontSize="13" TextElement.FontWeight="SemiBold">
                        <TextBlock Text="Ürünler" />
                        <TextBlock Text="{Binding Catalog.Products.Count, StringFormat=' ({0})'}"
                                   Foreground="{DynamicResource MutedBrush}" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="0,16,0,32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Ürünler" Style="{StaticResource DisplayText}" FontSize="22" />
                            <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,0">
                                <Run Text="{Binding Catalog.Products.Count, Mode=OneWay}" />
                                <Run Text=" ürün · " />
                                <Run Text="{Binding CalculatedPageCount, Mode=OneWay}" />
                                <Run Text=" sayfalık katalog (sayfa başına " />
                                <Run Text="{Binding ProductsPerLayoutPage, Mode=OneWay}" />
                                <Run Text=" ürün)" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource SecondaryButton}" Content="Tekli Ürün PNG"
                                    Margin="0,0,8,0" Command="{Binding CreateStandaloneProductPdfCommand}"
                                    ToolTip="Kataloğa eklemeden tek sayfalık ürün bilgi formu PNG görseli oluştur" />
                            <Button Style="{StaticResource SecondaryButton}" Content="Excel'den İçe Aktar"
                                    Margin="0,0,8,0" Command="{Binding ImportProductsFromExcelCommand}" />
                            <Button Style="{StaticResource SecondaryButton}" Content="Kütüphaneden Ekle"
                                    Margin="0,0,8,0" Command="{Binding OpenProductLibraryCommand}"
                                    ToolTip="Kayıtlı görsel ürün kütüphanesinden ürün ekle" />
                            <Button Style="{StaticResource SecondaryButton}" Content="Kütüphaneye Kaydet"
                                    Margin="0,0,8,0" Command="{Binding SaveProductsToLibraryCommand}"
                                    ToolTip="Bu katalogdaki ürünleri (görselleriyle) kütüphaneye kaydet — yeniden kullanım için" />
                            <Button Style="{StaticResource PrimaryButton}" Content="Ürün Ekle"
                                    Command="{Binding AddProductCommand}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,28,0,0">
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="48"
                                Visibility="{Binding Catalog.Products.Count, Converter={StaticResource CountToVisibility}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path Data="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z M3.27 6.96 12 12.01l8.73-5.05 M12 22.08V12"
                                      Width="40" Height="40" Stretch="Uniform"
                                      Stroke="{DynamicResource MutedBrush}" StrokeThickness="1.5" Fill="Transparent" />
                                <TextBlock Text="Henüz ürün eklenmedi" Style="{StaticResource BodyText}"
                                           FontWeight="SemiBold" Margin="0,16,0,4" HorizontalAlignment="Center" />
                                <TextBlock Text="Yukarıdan 'Ürün Ekle' ile katalogun ürünlerini ekleyin."
                                           Style="{StaticResource MutedText}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding Catalog.Products.Count, Converter={StaticResource CountToVisibility}, ConverterParameter=Inverted}">
                            <ItemsControl ItemsSource="{Binding Catalog.Products}" />
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Tasarımlar" FontFamily="{StaticResource BodyFont}"
                               FontSize="13" FontWeight="SemiBold" />
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,0,32">
                    <StackPanel Margin="0,12,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="PDF Tasarımları" Style="{StaticResource DisplayText}" FontSize="22" />
                                <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,0" TextWrapping="Wrap"
                                           Text="Aşağıdan kapak için bir tasarım seç. Üzerine tema renkleri ile marka ve katalog bilgileri yazılır." />
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="Görsel Klasörü"
                                    VerticalAlignment="Top" Margin="12,0,0,0"
                                    Command="{Binding OpenCoversFolderCommand}"
                                    ToolTip="Yüklenen tasarım görsellerinin bulunduğu klasörü aç" />
                        </Grid>

                        <Border Margin="0,20,0,0" />

                        <ItemsControl ItemsSource="{Binding DesignCards}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="220" Margin="0,0,16,16" Padding="0" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            Command="{Binding DataContext.SelectDesignCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Design.Id}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="DesignCardBorder" CornerRadius="10" Padding="14"
                                                        Background="{DynamicResource SurfaceBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2"
                                                        Effect="{StaticResource CardShadow}">
                                                    <StackPanel>
                                                        <Border CornerRadius="6" ClipToBounds="True"
                                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                                HorizontalAlignment="Center" Margin="0,0,0,12">
                                                            <!-- Gerçek kapak önizlemesi (DesignCardVM.Thumbnail) — elle çizilen XAML mini'lerin yerine -->
                                                            <Grid Width="170" Height="240" Background="{DynamicResource BackgroundBrush}">
                                                                <Image Source="{Binding Thumbnail}" Stretch="Uniform"
                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                <TextBlock Text="önizleme…" Style="{StaticResource MutedText}"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                           Visibility="{Binding Thumbnail, Converter={StaticResource NullToVisibility}, ConverterParameter=Inverted}" />
                                                            </Grid>
                                                        </Border>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Design.Name}" Style="{StaticResource BodyText}"
                                                                       FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                                                            <Border x:Name="SelectedBadge" Grid.Column="1"
                                                                    Background="{StaticResource AlgoYellowBrush}"
                                                                    CornerRadius="4" Padding="8,3" Visibility="Collapsed">
                                                                <TextBlock Text="SEÇİLİ" FontFamily="{StaticResource BodyFont}"
                                                                           FontSize="10" FontWeight="Bold" Foreground="#FFFFFFFF"
                                                                           VerticalAlignment="Center" />
                                                            </Border>
                                                        </Grid>
                                                        <TextBlock Text="{Binding Design.Description}" Style="{StaticResource MutedText}"
                                                                   TextWrapping="Wrap" Margin="0,6,0,0" />
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="DesignCardBorder" Property="BorderBrush" Value="{DynamicResource MutedBrush}" />
                                                    </Trigger>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource StringEquals}">
                                                                <Binding Path="DataContext.Catalog.DesignId" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                                <Binding Path="Design.Id" />
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter TargetName="DesignCardBorder" Property="BorderBrush" Value="{StaticResource AlgoYellowBrush}" />
                                                        <Setter TargetName="SelectedBadge" Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Sayfa Düzeni" FontFamily="{StaticResource BodyFont}"
                               FontSize="13" FontWeight="SemiBold" />
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,0,32">
                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="Sayfa Düzeni" Style="{StaticResource DisplayText}" FontSize="22" />
                        <TextBlock Text="Bir sayfa başına kaç ürün gireceğini seçin. Kart yüksekliği seçime göre otomatik ayarlanır."
                                   Style="{StaticResource MutedText}" Margin="0,4,0,20" TextWrapping="Wrap" />

                        <ItemsControl ItemsSource="{Binding AvailableLayouts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="220" Margin="0,0,16,16" Padding="0" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            Command="{Binding DataContext.SelectLayoutCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Id}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="LayoutCardBorder" CornerRadius="10" Padding="14"
                                                        Background="{DynamicResource SurfaceBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2"
                                                        Effect="{StaticResource CardShadow}">
                                                    <StackPanel>
                                                        <Border CornerRadius="6" ClipToBounds="True"
                                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                                HorizontalAlignment="Center" Margin="0,0,0,12">
                                                            <ContentControl Content="{Binding}"
                                                                            ContentTemplate="{StaticResource LayoutPreviewTemplate}" />
                                                        </Border>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource BodyText}"
                                                                       FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                                                            <Border x:Name="SelectedBadge" Grid.Column="1"
                                                                    Background="{StaticResource AlgoYellowBrush}"
                                                                    CornerRadius="4" Padding="8,3" Visibility="Collapsed">
                                                                <TextBlock Text="SEÇİLİ" FontFamily="{StaticResource BodyFont}"
                                                                           FontSize="10" FontWeight="Bold" Foreground="#FFFFFFFF"
                                                                           VerticalAlignment="Center" />
                                                            </Border>
                                                        </Grid>
                                                        <TextBlock Text="{Binding Summary}" Style="{StaticResource BodyText}"
                                                                   FontWeight="Medium" FontSize="11" Margin="0,4,0,0"
                                                                   Foreground="{StaticResource PrimaryBrush}" />
                                                        <TextBlock Text="{Binding Description}" Style="{StaticResource MutedText}"
                                                                   TextWrapping="Wrap" Margin="0,4,0,0" />
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="LayoutCardBorder" Property="BorderBrush" Value="{DynamicResource MutedBrush}" />
                                                    </Trigger>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource StringEquals}">
                                                                <Binding Path="DataContext.Catalog.LayoutId" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                                <Binding Path="Id" />
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter TargetName="LayoutCardBorder" Property="BorderBrush" Value="{StaticResource AlgoYellowBrush}" />
                                                        <Setter TargetName="SelectedBadge" Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Margin="0,24,0,0" Padding="0,24,0,0">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Sayfa Planlayıcı" Style="{StaticResource DisplayText}" FontSize="18" />
                                        <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,0">
                                            Açıldığında sayfalar tek tek elle düzenlenebilir: solda PDF sayfa önizlemesi,
                                            sağda ürün havuzu. Ürünleri sürükle-bırak ile slotlara yerleştirirsin.
                                            Bu seçenek kapalıyken sayfalar otomatik akar (Sayfa Düzeni yukarıdan seçilir).
                                        </TextBlock>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1" Style="{StaticResource ModernCheckBox}"
                                              Content="Sayfaları elle düzenle (manuel mod)"
                                              IsChecked="{Binding Catalog.UseCustomPageLayouts}"
                                              VerticalAlignment="Center" Margin="16,0,0,0" />
                                </Grid>

                                <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                    <Button Style="{StaticResource PrimaryButton}" Content="Sayfa Planlayıcı'yı Aç"
                                            Command="{Binding OpenPagePlannerCommand}" />
                                    <TextBlock Style="{StaticResource MutedText}" Margin="14,0,0,0" VerticalAlignment="Center">
                                        <Run Text="Şu anda " />
                                        <Run Text="{Binding Catalog.CustomPages.Count, Mode=OneWay}" />
                                        <Run Text=" sayfa planlanmış" />
                                    </TextBlock>
                                </StackPanel>

                                <!-- CustomPages alt-agaci (125 satir) kaldirildi 2026-05-22 Faz 30 cleanup. ViewModel command binding'leri (MoveCustomPageUp/Down/Remove/AddCustomPageCommand) ve code-behind handler'lari (OnAssignProductToPage, OnRemoveProductFromPage) orphan kaldi — derleme bozulmaz. Feature gerekirse XAML re-add edilir. -->
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Temalar" FontFamily="{StaticResource BodyFont}"
                               FontSize="13" FontWeight="SemiBold" />
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,0,32">
                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="PDF Temaları" Style="{StaticResource DisplayText}" FontSize="22" />
                        <TextBlock Text="Bir tema seçin — tüm PDF'lerde renk paleti ve başlık tipografisi bu temaya göre çizilir."
                                   Style="{StaticResource MutedText}" Margin="0,4,0,20" />

                        <ItemsControl ItemsSource="{Binding AvailableThemes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="280" Margin="0,0,16,16" Padding="0" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            Command="{Binding DataContext.SelectThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Id}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="ThemeCardBorder" CornerRadius="10" Padding="18"
                                                        Background="{DynamicResource SurfaceBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2"
                                                        Effect="{StaticResource CardShadow}">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource BodyText}"
                                                                       FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                                                            <Border x:Name="SelectedBadge" Grid.Column="1"
                                                                    Background="{StaticResource AlgoYellowBrush}"
                                                                    CornerRadius="4" Padding="8,3" Visibility="Collapsed">
                                                                <TextBlock Text="SEÇİLİ" FontFamily="{StaticResource BodyFont}"
                                                                           FontSize="10" FontWeight="Bold" Foreground="#FFFFFFFF"
                                                                           VerticalAlignment="Center" />
                                                            </Border>
                                                        </Grid>
                                                        <TextBlock Text="{Binding Description}" Style="{StaticResource MutedText}"
                                                                   TextWrapping="Wrap" Margin="0,6,0,12" />
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="40" Height="40" CornerRadius="4" Margin="0,0,6,0">
                                                                <Border.Background>
                                                                    <SolidColorBrush Color="{Binding PrimaryHex}" />
                                                                </Border.Background>
                                                            </Border>
                                                            <Border Width="40" Height="40" CornerRadius="4" Margin="0,0,6,0">
                                                                <Border.Background>
                                                                    <SolidColorBrush Color="{Binding SecondaryHex}" />
                                                                </Border.Background>
                                                            </Border>
                                                            <Border Width="40" Height="40" CornerRadius="4" Margin="0,0,6,0">
                                                                <Border.Background>
                                                                    <SolidColorBrush Color="{Binding AccentHex}" />
                                                                </Border.Background>
                                                            </Border>
                                                            <Border Width="40" Height="40" CornerRadius="4" Margin="0,0,6,0"
                                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                                                <Border.Background>
                                                                    <SolidColorBrush Color="{Binding SurfaceHex}" />
                                                                </Border.Background>
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThemeCardBorder" Property="BorderBrush" Value="{DynamicResource MutedBrush}" />
                                                    </Trigger>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource StringEquals}">
                                                                <Binding Path="DataContext.Catalog.ThemeId" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                                <Binding Path="Id" />
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter TargetName="ThemeCardBorder" Property="BorderBrush" Value="{StaticResource AlgoYellowBrush}" />
                                                        <Setter TargetName="SelectedBadge" Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Background="{DynamicResource SurfaceBrush}" Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Style="{StaticResource MutedText}" VerticalAlignment="Center">
                    <Run Text="{Binding Catalog.Products.Count, Mode=OneWay}" />
                    <Run Text=" ürün · " />
                    <Run Text="{Binding Catalog.References.Count, Mode=OneWay}" />
                    <Run Text=" referans · " />
                    <Run Text="{Binding CalculatedPageCount, Mode=OneWay}" />
                    <Run Text=" sayfa" />
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
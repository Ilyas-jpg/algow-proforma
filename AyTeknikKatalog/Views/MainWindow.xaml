                <Rectangle Canvas.Left="116" Canvas.Top="20" Width="40" Height="8" Fill="{StaticResource PvPrimary}" />
                <Rectangle Canvas.Left="0" Canvas.Top="34" Width="170" Height="84" Fill="{StaticResource PvPrimary}" />
                <Ellipse Canvas.Left="100" Canvas.Top="36" Width="80" Height="80" Stroke="{StaticResource PvAccent}" StrokeThickness="0.6" Fill="Transparent" Opacity="0.7" />
                <Ellipse Canvas.Left="118" Canvas.Top="54" Width="44" Height="44" Stroke="{StaticResource PvAccent}" StrokeThickness="0.5" Fill="Transparent" Opacity="0.6" />
                <Rectangle Canvas.Left="14" Canvas.Top="58" Width="60" Height="6" Fill="{StaticResource PvPaper}" />
                <Rectangle Canvas.Left="14" Canvas.Top="68" Width="42" Height="3" Fill="{StaticResource PvAccent}" />
                <Rectangle Canvas.Left="14" Canvas.Top="124" Width="3" Height="22" Fill="{StaticResource PvPrimary}" />
                <Rectangle Canvas.Left="22" Canvas.Top="126" Width="20" Height="14" Fill="{StaticResource PvPrimary}" />
                <Rectangle Canvas.Left="40" Canvas.Top="158" Width="90" Height="2" Fill="{StaticResource PvMuted}" />
                <Rectangle Canvas.Left="40" Canvas.Top="164" Width="80" Height="2" Fill="{StaticResource PvMuted}" />
                <Rectangle Canvas.Left="40" Canvas.Top="170" Width="86" Height="2" Fill="{StaticResource PvMuted}" />
                <Ellipse Canvas.Left="22" Canvas.Top="186" Width="14" Height="14" Stroke="{StaticResource PvPrimary}" StrokeThickness="0.7" Fill="Transparent" />
                <Ellipse Canvas.Left="64" Canvas.Top="186" Width="14" Height="14" Stroke="{StaticResource PvPrimary}" StrokeThickness="0.7" Fill="Transparent" />
                <Ellipse Canvas.Left="106" Canvas.Top="186" Width="14" Height="14" Stroke="{StaticResource PvPrimary}" StrokeThickness="0.7" Fill="Transparent" />
                <Ellipse Canvas.Left="148" Canvas.Top="186" Width="14" Height="14" Stroke="{StaticResource PvPrimary}" StrokeThickness="0.7" Fill="Transparent" />

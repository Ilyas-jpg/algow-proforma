<Window x:Class="AyTeknikKatalog.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AyTeknikKatalog.ViewModels"
        xmlns:conv="clr-namespace:AyTeknikKatalog.Converters"
        xmlns:m="clr-namespace:AyTeknikKatalog.Models"
        xmlns:local="clr-namespace:AyTeknikKatalog.Views"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="{Binding WindowTitle}"
        Width="1280" Height="820"
        MinWidth="1080" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/AppIcon.ico"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="{StaticResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        Closing="OnWindowClosing">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:PathToImageConverter x:Key="PathToImage" />
        <!-- NullToVisibility App.xaml'da global tanimli, burada redundant local define kaldirildi -->
        <conv:ProductIdLookupConverter x:Key="ProductIdLookup" />
        <conv:CountToVisibilityConverter x:Key="CountToVisibility" />
        <conv:PriceFormatConverter x:Key="PriceFormat" />
        <conv:StringEqualsConverter x:Key="StringEquals" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <SolidColorBrush x:Key="PvPrimary" Color="#2E338F" />
        <SolidColorBrush x:Key="PvSecondary" Color="#5368A6" />
        <SolidColorBrush x:Key="PvAccent" Color="#7C84C7" />
        <SolidColorBrush x:Key="PvSurface" Color="#EEEEF1" />
        <SolidColorBrush x:Key="PvMuted" Color="#9DA0A8" />
        <SolidColorBrush x:Key="PvText" Color="#1A1A1F" />
        <SolidColorBrush x:Key="PvPaper" Color="#FFFFFF" />

        <DataTemplate x:Key="LayoutPreviewTemplate">
            <Border Width="170" Height="240" Background="{StaticResource PvPaper}" ClipToBounds="True">
                <StackPanel>
                    <Border Height="20" Background="{StaticResource PvPrimary}" Margin="0,0,0,2" />
                    <Border Height="2" Background="{StaticResource PvAccent}" />
                    <Border Margin="10,12,10,0" Height="186">
                        <ItemsControl ItemsSource="{Binding Cells}" Tag="{Binding}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="{Binding DataContext.Columns, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                 Rows="{Binding DataContext.Rows, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="2" Background="{StaticResource PvSurface}" CornerRadius="2">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Border Grid.Row="0" Margin="3" Background="{StaticResource PvMuted}" Opacity="0.25" CornerRadius="1" />
                                            <Border Grid.Row="1" Background="{StaticResource PvPrimary}" Height="6" CornerRadius="0,0,2,2" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                    <Border Height="14" Background="{StaticResource PvPrimary}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <x:Array x:Key="CurrencyOptions" Type="sys:String">
            <sys:String>TL</sys:String>
            <sys:String>USD</sys:String>
            <sys:String>EUR</sys:String>
        </x:Array>

        <DataTemplate DataType="{x:Type m:Reference}">
            <Border x:Name="ReferenceCard" Margin="0,0,12,12" Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10"
                    Padding="16">
                <Grid>
                    <StackPanel>
                        <Border Height="80" Background="{DynamicResource BackgroundBrush}" CornerRadius="6">
                            <Grid>
                                <Image Source="{Binding LogoPath, Converter={StaticResource PathToImage}}"
                                       Stretch="Uniform" Margin="10"
                                       Visibility="{Binding LogoPath, Converter={StaticResource NullToVisibility}}" />
                                <TextBlock Text="{Binding Name}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontFamily="{StaticResource DisplayFont}" FontSize="20" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedBrush}"
                                           Visibility="{Binding LogoPath, Converter={StaticResource NullToVisibility}, ConverterParameter=Inverted}" />
                            </Grid>
                        </Border>
                        <TextBlock Text="{Binding Name}" Style="{StaticResource BodyText}"
                                   FontWeight="SemiBold" Margin="0,12,0,0" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border, Mode=FindAncestor}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Button Style="{StaticResource IconButton}" Width="28" Height="28"
                                Command="{Binding DataContext.EditReferenceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" ToolTip="Düzenle">
                            <Path Data="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z M15 5l4 4"
                                  Width="14" Height="14" Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.6" Fill="Transparent" />
                        </Button>
                        <Button Style="{StaticResource DangerIconButton}" Width="28" Height="28"
                                Command="{Binding DataContext.DeleteReferenceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" ToolTip="Sil">
                            <Path Data="M3 6h18 M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2 M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6 M10 11v6 M14 11v6"
                                  Width="14" Height="14" Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.6" Fill="Transparent" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type m:Product}">
            <Border Margin="0,0,0,8" Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10"
                    Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="64" Height="64" Background="{DynamicResource BackgroundBrush}" CornerRadius="6">
                        <Image Source="{Binding ImagePath, Converter={StaticResource PathToImage}}" Stretch="Uniform" Margin="6" />
                    </Border>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" Style="{StaticResource BodyText}" FontWeight="SemiBold"
                                       FontSize="13" TextTrimming="CharacterEllipsis" />
                            <Border Margin="10,0,0,0" Background="{StaticResource AlgoYellowBrush}" CornerRadius="3" Padding="6,2"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsFeatured, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="ÖNE ÇIKAN" FontSize="9" FontWeight="Bold" Foreground="#FFFFFFFF" />
                            </Border>
                            <Border Margin="6,0,0,0" CornerRadius="3" Padding="6,2"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding HasTable, Converter={StaticResource BoolToVisibility}}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#F5F6F7" Offset="0" />
                                        <GradientStop Color="#D6D8DC" Offset="0.55" />
                                        <GradientStop Color="#A9ADB3" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="TABLOLU" FontSize="9" FontWeight="Bold" Foreground="#FF1A1A1F" />
                            </Border>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding Code}" Style="{StaticResource MutedText}"
                                       Visibility="{Binding Code, Converter={StaticResource NullToVisibility}}" />
                            <TextBlock Text=" · " Style="{StaticResource MutedText}"
                                       Visibility="{Binding Code, Converter={StaticResource NullToVisibility}}" />
                            <TextBlock Style="{StaticResource BodyText}" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}">
                                <Run Text="{Binding Price, Converter={StaticResource PriceFormat}, Mode=OneWay}" />
                                <Run Text=" " />
                                <Run Text="{Binding Currency, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource IconButton}"
                                Command="{Binding DataContext.MoveProductUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" ToolTip="Yukarı taşı">
                            <Path Data="M12 19V5 M5 12l7-7 7 7" Width="14" Height="14" Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.6" Fill="Transparent" />
                        </Button>
                        <Button Style="{StaticResource IconButton}"
                                Command="{Binding DataContext.MoveProductDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" ToolTip="Aşağı taşı">
                            <Path Data="M12 5v14 M19 12l-7 7-7-7" Width="14" Height="14" Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.6" Fill="Transparent" />
                        </Button>
                        <Button Style="{StaticResource IconButton}"
                                Command="{Binding DataContext.GenerateSingleProductPdfCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" ToolTip="Ürün bilgi formu (tek sayfa PNG)">
                            <Path Data="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M9 13h6 M9 17h4"
                                  Width="14" Height="14" Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.6" Fill="Transparent" />
                        </Button>
                        <Button Style="{StaticResource IconButton}"
                                Command="{Binding DataContext.EditProductCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" ToolTip="Düzenle">
                            <Path Data="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z M15 5l4 4"
                                  Width="14" Height="14" Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.6" Fill="Transparent" />
                        </Button>
                        <Button Style="{StaticResource DangerIconButton}"
                                Command="{Binding DataContext.DeleteProductCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" ToolTip="Sil">
                            <Path Data="M3 6h18 M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2 M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6 M10 11v6 M14 11v6"
                                  Width="14" Height="14" Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.6" Fill="Transparent" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewCatalogCommand}" />
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenLatestPdfCommand}" />
        <KeyBinding Key="L" Modifiers="Control" Command="{Binding OpenLibraryCommand}" />
        <KeyBinding Key="P" Modifiers="Control" Command="{Binding GeneratePdfCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding GeneratePdfCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshPreviewCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource SurfaceBrush}" Padding="24,18"
                Effect="{StaticResource CardShadow}" Panel.ZIndex="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Image Source="pack://application:,,,/Resources/algow_wordmark.png"
                           Width="132" Height="40" Stretch="Uniform" HorizontalAlignment="Left" RenderOptions.BitmapScalingMode="HighQuality" />
                    <StackPanel VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock Text="Katalog &amp; Teklif Stüdyosu" Style="{StaticResource DisplayText}" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="Teklif · Proforma · Katalog Üretim Aracı" Style="{StaticResource MutedText}" Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ThemeToggleBtn" Style="{StaticResource IconButton}" Width="36" Height="36" Margin="0,0,8,0"
                            Click="OnThemeToggleClick" ToolTip="Açık / koyu tema değiştir">
                        <Path Data="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.39 5.39 0 0 1-7.54-7.54c-.44-.06-.9-.1-1.36-.1z"
                              Width="17" Height="17" Stretch="Uniform"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                    <Button Style="{StaticResource IconButton}" Width="36" Height="36" Margin="0,0,8,0"
                            Command="{Binding OpenPdfFolderCommand}" ToolTip="PDF klasörünü Dosya Gezgini'nde aç">
                        <Path Data="M3 7a2 2 0 0 1 2-2h4l2 2.5h8a2 2 0 0 1 2 2V18a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
                              Width="18" Height="18" Stretch="Uniform"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.6" Fill="Transparent"
                              StrokeLineJoin="Round" />
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" Content="Yeni" Margin="0,0,8,0"
                            Command="{Binding NewCatalogCommand}" ToolTip="Boş şablonla başla — Ctrl+N" />
                    <Button Style="{StaticResource SecondaryButton}" Content="Aç" Margin="0,0,8,0"
                            Command="{Binding OpenLatestPdfCommand}" ToolTip="En son PDF'i görüntüle — Ctrl+O" />
                    <Button Style="{StaticResource SecondaryButton}" Content="Kütüphane" Margin="0,0,8,0"
                            Command="{Binding OpenLibraryCommand}" ToolTip="Tüm üretilmiş PDF'ler — Ctrl+L" />
                    <Button x:Name="RecentBtn" Style="{StaticResource SecondaryButton}" Content="Son Kataloglar ▾" Margin="0,0,12,0"
                            ToolTip="Son açılan kataloglar"
                            Click="OnRecentButtonClick">
                        <Button.ContextMenu>
                            <ContextMenu ItemsSource="{Binding RecentEntries}">
                                <ContextMenu.ItemContainerStyle>
                                    <Style TargetType="MenuItem">
                                        <Setter Property="Header" Value="{Binding Name}" />
                                        <Setter Property="Command" Value="{Binding DataContext.LoadRecentCatalogCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <Setter Property="CommandParameter" Value="{Binding}" />
                                    </Style>
                                </ContextMenu.ItemContainerStyle>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="0,6,12,6" />
                    <Button Style="{StaticResource SecondaryButton}" Content="Teklif" Margin="0,0,8,0"
                            Click="OnNewQuoteClick" ToolTip="Yeni fiyat teklifi oluştur" />
                    <Button Style="{StaticResource SecondaryButton}" Content="Toplu Gönderim" Margin="0,0,8,0"
                            Click="OnBulkSendClick" ToolTip="Excel/CRM/elle alıcılara toplu teklif e-postası" />
                    <Button Style="{StaticResource SecondaryButton}" Content="Fiyat Listesi" Margin="0,0,8,0"
                            Click="OnPriceBookClick" ToolTip="Ürün ve birim fiyat havuzu" />
                    <Button Style="{StaticResource SecondaryButton}" Content="Müşteriler" Margin="0,0,8,0"
                            Click="OnCustomersClick" ToolTip="Müşteri / kişi listesi" />
                    <Button Style="{StaticResource SecondaryButton}" Content="Ayarlar" Margin="0,0,12,0"
                            Click="OnSettingsClick" ToolTip="Mail hesabı ve e-posta şablonu" />
                    <Button Style="{StaticResource PrimaryButton}" Content="PDF Üret"
                            Command="{Binding GeneratePdfCommand}" ToolTip="Düzenlemeyi tamamla ve PDF üret — Ctrl+P" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Style="{StaticResource ModernTabControl}" Padding="0" Margin="24,0">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem" BasedOn="{StaticResource ModernTabItem}" />
            </TabControl.ItemContainerStyle>

            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Marka Bilgileri" FontFamily="{StaticResource BodyFont}"
                               FontSize="13" FontWeight="SemiBold" />
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,0,32">
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" MaxWidth="640" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10" Height="200"
                                    Effect="{StaticResource CardShadow}">
                                <Grid>
                                    <Image Source="{Binding Catalog.Brand.LogoPath, Converter={StaticResource PathToImage}}"
                                           Stretch="Uniform" Margin="20"
                                           Visibility="{Binding Catalog.Brand.LogoPath, Converter={StaticResource NullToVisibility}}" />
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Visibility="{Binding Catalog.Brand.LogoPath, Converter={StaticResource NullToVisibility}, ConverterParameter=Inverted}">
                                        <Path Data="M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z M9 9a2 2 0 1 1 0-4 2 2 0 0 1 0 4z M21 15l-5-5L5 21"
                                              Width="32" Height="32" Stretch="Uniform"
                                              Stroke="{DynamicResource MutedBrush}" StrokeThickness="1.5" Fill="Transparent" />
                                        <TextBlock Text="Henüz logo yüklenmedi" Style="{StaticResource MutedText}"
                                                   Margin="0,12,0,0" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Button Style="{StaticResource SecondaryButton}" Content="Logo Seç"
                                    Margin="0,12,0,0" HorizontalAlignment="Stretch"
                                    Command="{Binding BrowseBrandLogoCommand}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Marka Adı (zorunlu)" Style="{StaticResource LabelText}" />
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Catalog.Brand.Name, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="Slogan / Alt Başlık" Style="{StaticResource LabelText}" Margin="0,16,0,6" />
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Catalog.Brand.Tagline, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="Filigran (boşsa kapatılır — örn: TASLAK, ÖRNEKTİR, FİRMA 2026)" Style="{StaticResource LabelText}" Margin="0,16,0,6" />
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Catalog.Brand.WatermarkText, UpdateSourceTrigger=PropertyChanged}" />

                            <CheckBox Style="{StaticResource ModernCheckBox}" Margin="0,16,0,0"
                                      Content="Logonun arkasında beyaz dikdörtgen göster"
                                      IsChecked="{Binding Catalog.Brand.ShowLogoBackground}"
                                      ToolTip="Açıksa logo beyaz kart içinde gözükür. Kapalıysa logo direkt sayfada (şeffaf arka plan)." />

                            <TextBlock Text="Hakkımızda Metni" Style="{StaticResource LabelText}" Margin="0,16,0,6" />
                            <TextBox Style="{StaticResource ModernTextBox}" Height="120"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"
                                     Text="{Binding Catalog.Brand.About, UpdateSourceTrigger=PropertyChanged}" />

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Telefon" Style="{StaticResource LabelText}" />
                                    <TextBox Style="{StaticResource ModernTextBox}"
                                             Text="{Binding Catalog.Brand.Phone, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="E-posta" Style="{StaticResource LabelText}" />
                                    <TextBox Style="{StaticResource ModernTextBox}"
                                             Text="{Binding Catalog.Brand.Email, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Web" Style="{StaticResource LabelText}" />
                                    <TextBox Style="{StaticResource ModernTextBox}"
                                             Text="{Binding Catalog.Brand.Web, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Adres" Style="{StaticResource LabelText}" />
                                    <TextBox Style="{StaticResource ModernTextBox}"
                                             Text="{Binding Catalog.Brand.Address, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Kapak Sayfası" FontFamily="{StaticResource BodyFont}"
                               FontSize="13" FontWeight="SemiBold" />
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,0,32">
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MaxWidth="640" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Top">
                            <TextBlock Text="Canlı Önizleme" Style="{StaticResource LabelText}" Margin="0,0,0,6" />
                            <TextBlock Text="Seçili tasarım + yüklenen görsel ile A4 kapağın nasıl görüneceği. Tasarım değiştirince veya görsel yükleyince otomatik yenilenir."
                                       Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource BackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6"
                                    Width="320" Height="452" HorizontalAlignment="Left">
                                <Grid>
                                    <Image Source="{Binding CoverPreviewImage}" Stretch="Uniform" Margin="2" />
                                    <TextBlock Text="Önizleme yükleniyor..." Style="{StaticResource MutedText}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Visibility="{Binding IsCoverPreviewLoading, Converter={StaticResource BoolToVisibility}}" />
                                </Grid>
                            </Border>
                            <Button Style="{StaticResource SecondaryButton}" Content="Önizlemeyi Yenile"
                                    Command="{Binding RefreshPreviewCommand}" Margin="0,12,0,0" HorizontalAlignment="Left" />
                        </StackPanel>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Bu alandaki düzenlemeler sadece PDF'in ilk sayfasını etkiler. Boş bırakılan alanlar varsayılan değerle (marka adı/yıl/açıklama) doldurulur."
                                       Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,18" />

                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,16"
                                    Effect="{StaticResource CardShadow}">
                                <StackPanel>
                                    <TextBlock Text="🎨 Kapak Tasarım Stüdyosu (Canva tarzı sürükle-bırak)" Style="{StaticResource LabelText}" Margin="0,0,0,4" FontWeight="SemiBold" />
                                    <TextBlock Text="Tam kontrol: fotoğraf, başlık, metin, kutu, çizgi elementlerini sürükle-bırak ile yerleştir. Katman sıralı (z-index), kırpma + boyutlandırma. Boş bırakırsan seçili tasarım kullanılır."
                                               Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,10" />
                                    <StackPanel Orientation="Horizontal">

<Window x:Class="AyTeknikKatalog.Views.PagePlannerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AyTeknikKatalog.Converters"
        xmlns:m="clr-namespace:AyTeknikKatalog.Models"
        Width="1280" Height="820" MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="{StaticResource BodyFont}"
        Title="Sayfa Planlayıcı"
        PreviewMouseMove="OnWindowMouseMove"
        PreviewMouseLeftButtonUp="OnProductMouseUp">

    <Window.Resources>
        <conv:PathToImageConverter x:Key="PathToImage" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibility" />
        <conv:ProductIdLookupConverter x:Key="ProductIdLookup" />
        <conv:PriceFormatConverter x:Key="PriceFormat" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Üst başlık -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="24,14"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Sayfa Planlayıcı" Style="{StaticResource DisplayText}" FontSize="18" />
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,3,0,0">
                        Sağ taraftaki ürünleri basılı tutup sol taraftaki sayfa slotlarına sürükle.
                        Alttaki oklarla sayfalar arasında geçiş yapabilirsin.
                    </TextBlock>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource PrimaryButton}"
                        Content="Tamam" Click="OnDone" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- İçerik: sol sayfa önizleme, sağ ürün listesi -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <!-- Sol: Sayfa önizleme (A4 oranı simülasyonu) -->
            <Grid Grid.Column="0" Margin="24,18,12,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- A4 oranlı sayfa container -->
                <Viewbox Grid.Row="0" Stretch="Uniform">
                    <Border Width="595" Height="842" Background="White"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1.5">
                        <Grid Margin="36,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Sayfa header simülasyonu -->
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="24" Height="24"
                                        Background="{StaticResource PrimaryBrush}">
                                    <TextBlock Text="AT" FontSize="10" Foreground="White" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center"
                                           Foreground="#FF333333" FontSize="11" FontWeight="SemiBold"
                                           Text="{Binding BrandName}" />
                                <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                           Foreground="#FF7C84C7" FontSize="9" FontWeight="Bold"
                                           Text="ÜRÜN KATALOĞU" />
                            </Grid>
                            <Rectangle Grid.Row="0" VerticalAlignment="Bottom" Height="1" Fill="#FFD0D0D0" />

                            <!-- Slot grid — code-behind tarafından inşa edilir (span destekli) -->
                            <Grid x:Name="SlotGrid" Grid.Row="1" Margin="0,12,0,12" />

                            <!-- Footer simülasyonu -->
                            <Rectangle Grid.Row="2" VerticalAlignment="Top" Height="1" Fill="#FFD0D0D0" Margin="0,0,0,4" />
                            <Grid Grid.Row="2" Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Foreground="#FF888888" FontSize="9"
                                           Text="{Binding BrandName}" />
                                <TextBlock Grid.Column="1" Foreground="#FF333333" FontSize="9" FontWeight="SemiBold"
                                           Text="{Binding PageNumberFooter}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Viewbox>

                <!-- Sayfa kontrolleri -->
                <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" Padding="14,10"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6"
                        Margin="0,14,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Önceki / sonraki / sayfa no -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button Style="{StaticResource IconButton}" Width="36" Height="32" Click="OnPrevPage"
                                    ToolTip="Önceki sayfa">
                                <Path Data="M15 18l-6-6 6-6" Width="14" Height="14" Stretch="Uniform"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.8" Fill="Transparent" />
                            </Button>
                            <TextBlock VerticalAlignment="Center" Margin="10,0" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Text="{Binding PageNumberLabel}" />
                            <Button Style="{StaticResource IconButton}" Width="36" Height="32" Click="OnNextPage"
                                    ToolTip="Sonraki sayfa">
                                <Path Data="M9 18l6-6-6-6" Width="14" Height="14" Stretch="Uniform"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.8" Fill="Transparent" />
                            </Button>
                        </StackPanel>

                        <TextBlock Grid.Column="1" />

                        <!-- Sayfa düzeni -->
                        <TextBlock Grid.Column="2" Text="Düzen:" Style="{StaticResource LabelText}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox Grid.Column="3" x:Name="LayoutBox" Style="{StaticResource ModernComboBox}"
                                  Width="160" DisplayMemberPath="Name" SelectedValuePath="Id"
                                  SelectionChanged="OnLayoutChanged" />

                        <!-- Sayfa ekle / sil -->
                        <Button Grid.Column="4" Style="{StaticResource SecondaryButton}" Content="+ Sayfa"
                                Margin="14,0,4,0" Click="OnAddPage" />
                        <Button Grid.Column="5" Style="{StaticResource DangerIconButton}" Width="36" Height="32"
                                Click="OnDeletePage" ToolTip="Bu sayfayı sil">
                            <Path Data="M3 6h18 M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2 m3 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"
                                  Width="14" Height="14" Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.6" Fill="Transparent" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <!-- Sağ: Ürün listesi -->
            <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" Margin="12,18,24,18"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="14,12"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="ÜRÜNLER" Style="{StaticResource LabelText}" Margin="0" FontSize="10" />
                            <TextBlock Style="{StaticResource MutedText}" Margin="0,3,0,0">
                                <Run Text="{Binding Catalog.Products.Count, Mode=OneWay}" />
                                <Run Text=" ürün · Sürükleyip slota bırak" />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled" Padding="8">
                        <ItemsControl x:Name="ProductPalette" ItemsSource="{Binding Catalog.Products}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="ProductRow" Background="{StaticResource BackgroundBrush}"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="6" Margin="0,0,0,6" Padding="8"
                                            PreviewMouseLeftButtonDown="OnProductMouseDown"
                                            PreviewMouseLeftButtonUp="OnProductMouseUp"
                                            Cursor="Hand"
                                            Tag="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="48" Height="48"
                                                    Background="{StaticResource SurfaceBrush}" CornerRadius="4">
                                                <Image Source="{Binding ImagePath, Converter={StaticResource PathToImage}}"
                                                       Stretch="Uniform" Margin="4" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                                               Foreground="{StaticResource TextBrush}"
                                                               TextTrimming="CharacterEllipsis" MaxWidth="160" />
                                                    <Border Margin="6,0,0,0" Background="{StaticResource AlgoYellowBrush}" CornerRadius="3"
                                                            Padding="4,1" VerticalAlignment="Center"
                                                            Visibility="{Binding IsFeatured, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="ÖNE" FontSize="8" FontWeight="Bold" Foreground="#FF1A1A1F" />
                                                    </Border>
                                                    <Border Margin="3,0,0,0" CornerRadius="3" Padding="4,1" VerticalAlignment="Center"
                                                            Visibility="{Binding HasTable, Converter={StaticResource BoolToVisibility}}">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#F5F6F7" Offset="0" />
                                                                <GradientStop Color="#D6D8DC" Offset="0.55" />
                                                                <GradientStop Color="#A9ADB3" Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <TextBlock Text="TBL" FontSize="8" FontWeight="Bold" Foreground="#FF1A1A1F" />
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding Code}" Style="{StaticResource MutedText}" FontSize="10" />
                                                    <TextBlock Text=" · " Style="{StaticResource MutedText}" FontSize="10"
                                                               Visibility="{Binding Code, Converter={StaticResource NullToVisibility}}" />
                                                    <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}">
                                                        <Run Text="{Binding Price, Converter={StaticResource PriceFormat}, Mode=OneWay}" />
                                                        <Run Text=" " />
                                                        <Run Text="{Binding Currency, Mode=OneWay}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                            <Border Grid.Column="2" x:Name="AssignedBadge"
                                                    Background="{StaticResource AlgoYellowBrush}" CornerRadius="3"
                                                    Padding="6,2" VerticalAlignment="Center" Margin="0,0,4,0"
                                                    Visibility="Collapsed">
                                                <TextBlock Text="✓" FontSize="11" FontWeight="Bold" Foreground="#FF1A1A1F" />
                                            </Border>
                                            <Button Grid.Column="3" Style="{StaticResource IconButton}" Width="28" Height="28"
                                                    Click="OnEditProductFromPalette" Tag="{Binding}" ToolTip="Düzenle">
                                                <Path Data="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z M15 5l4 4"
                                                      Width="12" Height="12" Stretch="Uniform"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      StrokeThickness="1.6" Fill="Transparent" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Alt status -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" Padding="24,10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText" Style="{StaticResource MutedText}" FontSize="11" />
        </Border>
    </Grid>
</Window>

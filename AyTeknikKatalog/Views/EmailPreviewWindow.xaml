<Window x:Class="AyTeknikKatalog.Views.EmailPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="E-posta Onizleme - Algow Proforma PDF"
        Width="820" Height="720"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="{StaticResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="E-posta Onizleme" Style="{StaticResource DisplayText}" FontSize="22" FontWeight="Bold" Margin="0,0,0,12" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="16" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Firma" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,8" />
                        <TextBlock x:Name="CompanyText" Grid.Row="0" Grid.Column="1" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" Margin="0,0,0,8" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Yetkili" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,8" />
                        <TextBlock x:Name="ContactText" Grid.Row="1" Grid.Column="1" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="E-posta" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,8" />
                        <TextBox x:Name="ToEmailBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource ModernTextBox}" Margin="0,0,0,8" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Ek" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,8" />
                        <TextBlock x:Name="AttachmentText" Grid.Row="3" Grid.Column="1" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Gonderici" Foreground="{DynamicResource MutedBrush}" />
                        <TextBlock x:Name="ProviderText" Grid.Row="4" Grid.Column="1" Foreground="{DynamicResource TextBrush}" />
                    </Grid>
                </Border>

                <TextBlock Text="Konu" Style="{StaticResource MutedText}" />
                <TextBox x:Name="SubjectBox" Style="{StaticResource ModernTextBox}" Margin="0,2,0,12" />

                <TextBlock Text="E-posta govdesi" Style="{StaticResource MutedText}" />
                <TextBox x:Name="BodyBox" Style="{StaticResource ModernTextBox}" Margin="0,2,0,0" Height="300"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="0,14,0,0">
            <TextBlock x:Name="StatusText" DockPanel.Dock="Left" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" TextWrapping="Wrap" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="GmailButton" Style="{StaticResource PrimaryButton}" Content="Send with Gmail" Click="OnSendGmail" />
                <Button x:Name="SmtpButton" Style="{StaticResource SecondaryButton}" Content="Send with SMTP" Margin="8,0,0,0" Click="OnSendSmtp" />
                <Button Style="{StaticResource SecondaryButton}" Content="Kapat" Margin="8,0,0,0" Click="OnClose" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>

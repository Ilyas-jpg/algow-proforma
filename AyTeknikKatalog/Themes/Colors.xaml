<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="BackgroundColor">#FF0E0E14</Color>
    <Color x:Key="SurfaceColor">#FF1B1B24</Color>
    <Color x:Key="ElevatedSurfaceColor">#FF24242E</Color>
    <Color x:Key="BorderColor">#FF2C2C38</Color>
    <Color x:Key="TextColor">#FFF1F1F4</Color>
    <Color x:Key="MutedColor">#FF888A95</Color>
    <Color x:Key="OverlayColor">#AA000000</Color>

    <Color x:Key="DangerColor">#FFE25C44</Color>
    <Color x:Key="DangerSurfaceColor">#FF3A1F1A</Color>

    <!-- Uygulama arayüzü sıcak bakır aksan paleti (primary #C2410C, accent #EA8A4B, secondary #9A3412).
         Anahtar isimleri AlgoYellow* legacy korundu (XAML'de yaygın referans var); sadece değerler güncellendi.
         NOT: Bu yalnızca UYGULAMA ARAYÜZÜ temasıdır — üretilen PDF/teklif renkleri PdfTheme sisteminden gelir (white-label). -->
    <Color x:Key="AlgoYellowLightColor">#FFEA8A4B</Color>
    <Color x:Key="AlgoYellowDeepColor">#FF9A3412</Color>
    <Color x:Key="AlgoYellowSoftColor">#33C2410C</Color>
    <Color x:Key="AlgoYellowFocusColor">#FFC2410C</Color>

    <Color x:Key="PrimaryColor">#FFC2410C</Color>
    <Color x:Key="SecondaryColor">#FFEA8A4B</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="ElevatedSurfaceBrush" Color="{StaticResource ElevatedSurfaceColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}" />
    <SolidColorBrush x:Key="OverlayBrush" Color="{StaticResource OverlayColor}" />

    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="DangerSurfaceBrush" Color="{StaticResource DangerSurfaceColor}" />

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}" />
    <SolidColorBrush x:Key="AlgoYellowSoftBrush" Color="{StaticResource AlgoYellowSoftColor}" />

    <!-- Sıcak bakır gradient (EA8A4B → 9A3412) -->
    <LinearGradientBrush x:Key="AlgoYellowBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AlgoYellowLightColor}" Offset="0" />
        <GradientStop Color="{StaticResource AlgoYellowDeepColor}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AlgoYellowHoverBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFAD9B8" Offset="0" />
        <GradientStop Color="#FFC2410C" Offset="1" />
    </LinearGradientBrush>

    <Geometry x:Key="AlgoStarGeometry">M 12 0 Q 12 12 24 12 Q 12 12 12 24 Q 12 12 0 12 Q 12 12 12 0 Z</Geometry>

    <FontFamily x:Key="DisplayFont">Segoe UI</FontFamily>
    <FontFamily x:Key="BodyFont">Segoe UI</FontFamily>

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════════════════════════════════
         Algow Proforma — tema paleti (varsayılan = DARK).
         Runtime'da Services/ThemeManager brush'ların .Color'unu Dark/Light arası
         değiştirir. Brush'lar StaticResource ile paylaşıldığından canlı güncellenir
         → bu yüzden hiçbiri FROZEN değildir.
         Marka: obsidyen zemin + kobalt aksan (#3D5BFF) + altın yalnız logo/vurgu. -->

    <!-- Katmanlı yüzeyler (dark default — ThemeManager.Dark ile birebir aynı olmalı).
         Background = canvas + inset alan dolgusu · Surface = kart/panel/app-bar · Elevated = hover/seçili. -->
    <Color x:Key="BackgroundColor">#FF0D0D13</Color>
    <Color x:Key="SurfaceColor">#FF17171F</Color>
    <Color x:Key="ElevatedSurfaceColor">#FF202230</Color>
    <Color x:Key="BorderColor">#FF2A2B38</Color>
    <Color x:Key="TextColor">#FFF3F4F8</Color>
    <Color x:Key="MutedColor">#FF8E90A0</Color>
    <Color x:Key="OverlayColor">#B3050507</Color>

    <Color x:Key="DangerColor">#FFFF6B6B</Color>
    <Color x:Key="DangerSurfaceColor">#FF3A1F22</Color>

    <!-- Aksan: kobalt. (AlgoYellow* anahtar adları legacy — XAML'de yaygın referans var,
         yalnızca DEĞERLER kobalta çevrildi. Aksan her iki temada aynı kalır.) -->
    <Color x:Key="AlgoYellowLightColor">#FF4E6BFF</Color>
    <Color x:Key="AlgoYellowDeepColor">#FF2E49E6</Color>
    <Color x:Key="AlgoYellowSoftColor">#293D5BFF</Color>
    <Color x:Key="AlgoYellowFocusColor">#FF3D5BFF</Color>

    <Color x:Key="PrimaryColor">#FF3D5BFF</Color>
    <Color x:Key="SecondaryColor">#FF5872FF</Color>

    <!-- Tema brush'ları FALLBACK (dark) tanımı. Asıl runtime renkleri ThemeManager'ın eklediği
         "palette" merged-dictionary'sinden gelir; UI bunlara {DynamicResource XBrush} ile bağlanır →
         palette en sona merge edildiği için onu çözer. Buradakiler yalnız palette eklenmeden önceki
         ilk an + gözden kaçan StaticResource referansları için güvenlik ağı (frozen, sorun değil). -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="ElevatedSurfaceBrush" Color="{StaticResource ElevatedSurfaceColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}" />
    <SolidColorBrush x:Key="OverlayBrush" Color="{StaticResource OverlayColor}" />

    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="DangerSurfaceBrush" Color="{StaticResource DangerSurfaceColor}" />

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}" />
    <SolidColorBrush x:Key="AlgoYellowSoftBrush" Color="{StaticResource AlgoYellowSoftColor}" />

    <!-- Aksan üstü metin (kobalt buton/checkbox üstünde) — her iki temada beyaz -->
    <SolidColorBrush x:Key="OnAccentBrush" Color="#FFFFFFFF" />
    <!-- Marka altını — yalnız logo/seçili premium vurgu (her iki temada sabit) -->
    <SolidColorBrush x:Key="GoldBrush" Color="#FFFFD500" />

    <!-- Aksan gradient (PrimaryButton) — kobalt, dikey -->
    <LinearGradientBrush x:Key="AlgoYellowBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource AlgoYellowLightColor}" Offset="0" />
        <GradientStop Color="{StaticResource AlgoYellowDeepColor}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AlgoYellowHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF6177FF" Offset="0" />
        <GradientStop Color="#FF3D5BFF" Offset="1" />
    </LinearGradientBrush>

    <Geometry x:Key="AlgoStarGeometry">M 12 0 Q 12 12 24 12 Q 12 12 12 24 Q 12 12 0 12 Q 12 12 12 0 Z</Geometry>

    <!-- Tipografi: Segoe UI Variable (Win11 native, optik ölçekli — düz Segoe UI'dan belirgin upgrade;
         Win10'da otomatik Segoe UI'a düşer). Inter/Jakarta bundling = opsiyonel follow-up. -->
    <FontFamily x:Key="DisplayFont">Segoe UI Variable Display</FontFamily>
    <FontFamily x:Key="BodyFont">Segoe UI Variable Text</FontFamily>

    <!-- Paylaşılan yumuşak gölge — kart/panel/app-bar'ın canvas üstünde yükselmesi için.
         Tek değer iki temada da çalışır: light'ta belirgin, dark'ta ince derinlik dikişi.
         WPF DropShadowEffect yalnız gölgeyi blur'lar (element net kalır) + RenderingBias=Performance. -->
    <DropShadowEffect x:Key="CardShadow" Color="#FF000000" BlurRadius="20" ShadowDepth="3"
                      Direction="270" Opacity="0.26" RenderingBias="Performance" />

</ResourceDictionary>

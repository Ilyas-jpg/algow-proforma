<Window x:Class="AlgowProforma.Views.CoverDesignerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:m="clr-namespace:AlgowProforma.Models"
        Title="Kapak Tasarım Stüdyosu — Algow Proforma PDF"
        Width="1280" Height="820"
        MinWidth="1000" MinHeight="640"
        MaxWidth="{x:Static SystemParameters.MaximizedPrimaryScreenWidth}"
        MaxHeight="{x:Static SystemParameters.MaximizedPrimaryScreenHeight}"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F7"
        FontFamily="{StaticResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <!-- SOL PANEL: Element Paleti -->
        <Border Grid.Row="0" Grid.Column="0" Background="White" BorderBrush="#E5E5E7" BorderThickness="0,0,1,0">
            <StackPanel Margin="16">
                <TextBlock Text="ELEMENT PALETİ" FontSize="11" FontWeight="Bold" Foreground="#818285"
                           Margin="0,0,0,12" />
                <Button Content="🖼  Görsel Ekle" Command="{Binding AddImageCommand}"
                        Style="{StaticResource SecondaryButton}" HorizontalAlignment="Stretch" Margin="0,0,0,6" />
                <Button Content="🅣  Başlık" Command="{Binding AddTitleCommand}"
                        Style="{StaticResource SecondaryButton}" HorizontalAlignment="Stretch" Margin="0,0,0,6" />
                <Button Content="📝 Metin" Command="{Binding AddTextCommand}"
                        Style="{StaticResource SecondaryButton}" HorizontalAlignment="Stretch" Margin="0,0,0,6" />
                <Button Content="▭  Kutu" Command="{Binding AddRectCommand}"
                        Style="{StaticResource SecondaryButton}" HorizontalAlignment="Stretch" Margin="0,0,0,6" />
                <Button Content="─  Çizgi" Command="{Binding AddLineCommand}"
                        Style="{StaticResource SecondaryButton}" HorizontalAlignment="Stretch" Margin="0,0,0,16" />

                <TextBlock Text="ELEMENT İŞLEMLERİ" FontSize="11" FontWeight="Bold" Foreground="#818285"
                           Margin="0,8,0,8" />
                <Button Content="Kopyala (Ctrl+D)" Command="{Binding DuplicateCommand}"
                        Style="{StaticResource SecondaryButton}" HorizontalAlignment="Stretch" Margin="0,0,0,6" />
                <Button Content="Sil" Command="{Binding DeleteElementCommand}"
                        Style="{StaticResource SecondaryButton}" HorizontalAlignment="Stretch" Margin="0,0,0,6" />
                <Button Content="↑ Öne Getir" Command="{Binding BringForwardCommand}"
                        Style="{StaticResource SecondaryButton}" HorizontalAlignment="Stretch" Margin="0,0,0,6" />
                <Button Content="↓ Arkaya Gönder" Command="{Binding SendBackwardCommand}"
                        Style="{StaticResource SecondaryButton}" HorizontalAlignment="Stretch" Margin="0,0,0,12" />

                <Button Content="🗑  Hepsini Temizle" Command="{Binding ClearAllCommand}"
                        Style="{StaticResource SecondaryButton}" HorizontalAlignment="Stretch" />
            </StackPanel>
        </Border>

        <!-- ORTA PANEL: Canvas (A4 önizleme) -->
        <Border Grid.Row="0" Grid.Column="1" Background="#E5E5E7" Padding="20">
            <Grid>
                <Border x:Name="CanvasBorder" Background="White" Width="525" Height="742"
                        BorderBrush="#C4BCB4" BorderThickness="1"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        SnapsToDevicePixels="True">
                    <Canvas x:Name="DesignCanvas" Width="525" Height="742" ClipToBounds="True"
                            MouseDown="OnCanvasMouseDown">
                        <ItemsControl ItemsSource="{Binding Elements}" Width="525" Height="742">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="525" Height="742" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left">
                                        <Setter.Value>
                                            <MultiBinding Converter="{StaticResource MmToPxConverter}">
                                                <Binding Path="XMm" />
                                                <Binding Source="2.5" />
                                            </MultiBinding>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Canvas.Top">
                                        <Setter.Value>
                                            <MultiBinding Converter="{StaticResource MmToPxConverter}">
                                                <Binding Path="YMm" />
                                                <Binding Source="2.5" />
                                            </MultiBinding>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Panel.ZIndex" Value="{Binding ZIndex}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type m:CoverElement}">
                                    <Border BorderBrush="#7C84C7" BorderThickness="0"
                                            MouseDown="OnElementMouseDown" Background="Transparent"
                                            Tag="{Binding}">
                                        <Border.Width>
                                            <MultiBinding Converter="{StaticResource MmToPxConverter}">
                                                <Binding Path="WidthMm" />
                                                <Binding Source="2.5" />
                                            </MultiBinding>
                                        </Border.Width>
                                        <Border.Height>
                                            <MultiBinding Converter="{StaticResource MmToPxConverter}">
                                                <Binding Path="HeightMm" />
                                                <Binding Source="2.5" />
                                            </MultiBinding>
                                        </Border.Height>
                                        <Grid>
                                            <ContentControl Content="{Binding}" ContentTemplateSelector="{StaticResource CoverElementTemplates}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Selected element resize handle (sağ alt köşe) -->
                        <Thumb x:Name="ResizeThumb" Width="14" Height="14" Cursor="SizeNWSE"
                               Background="#2E338F" Visibility="Collapsed"
                               DragDelta="OnResizeThumbDragDelta">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Border Background="#2E338F" BorderBrush="White" BorderThickness="2" CornerRadius="2" />
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </Canvas>
                </Border>
            </Grid>
        </Border>

        <!-- SAĞ PANEL: Özellikler -->
        <Border Grid.Row="0" Grid.Column="2" Background="White" BorderBrush="#E5E5E7" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                <StackPanel DataContext="{Binding SelectedElement}">
                    <TextBlock Text="ÖZELLİKLER" FontSize="11" FontWeight="Bold" Foreground="#818285"
                               Margin="0,0,0,12" />
                    <StackPanel Visibility="{Binding Converter={StaticResource NullToVisibility}}">

                        <TextBlock Text="Tip" Style="{StaticResource LabelText}" />
                        <TextBlock Text="{Binding Type}" FontWeight="SemiBold" Margin="0,2,0,12" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="X (mm)" Style="{StaticResource LabelText}" />
                                <TextBox Style="{StaticResource ModernTextBox}"
                                         Text="{Binding XMm, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F1}}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Y (mm)" Style="{StaticResource LabelText}" />
                                <TextBox Style="{StaticResource ModernTextBox}"
                                         Text="{Binding YMm, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F1}}" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Genişlik (mm)" Style="{StaticResource LabelText}" />
                                <TextBox Style="{StaticResource ModernTextBox}"
                                         Text="{Binding WidthMm, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F1}}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Yükseklik (mm)" Style="{StaticResource LabelText}" />
                                <TextBox Style="{StaticResource ModernTextBox}"
                                         Text="{Binding HeightMm, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F1}}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="İçerik" Style="{StaticResource LabelText}" Margin="0,12,0,0" />
                        <TextBox Style="{StaticResource ModernTextBox}" Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                                 Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}" />

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Yazı Boyutu" Style="{StaticResource LabelText}" />
                                <TextBox Style="{StaticResource ModernTextBox}"
                                         Text="{Binding FontSize, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F0}}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Şeffaflık" Style="{StaticResource LabelText}" />
                                <TextBox Style="{StaticResource ModernTextBox}"
                                         Text="{Binding Opacity, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" />
                            </StackPanel>
                        </Grid>

                        <CheckBox Content="Kalın (Bold)" IsChecked="{Binding Bold}" Margin="0,12,0,4" />
                        <CheckBox Content="İtalik" IsChecked="{Binding Italic}" Margin="0,0,0,12" />

                        <TextBlock Text="Yazı Rengi (#hex)" Style="{StaticResource LabelText}" />
                        <TextBox Style="{StaticResource ModernTextBox}"
                                 Text="{Binding ForegroundHex, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Arka Plan Rengi (boşsa şeffaf)" Style="{StaticResource LabelText}" Margin="0,8,0,0" />
                        <TextBox Style="{StaticResource ModernTextBox}"
                                 Text="{Binding BackgroundHex, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Z-Sıra" Style="{StaticResource LabelText}" Margin="0,8,0,0" />
                        <TextBox Style="{StaticResource ModernTextBox}"
                                 Text="{Binding ZIndex, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <TextBlock Text="Düzenlemek için bir element seç" Foreground="#818285" FontStyle="Italic"
                               Visibility="{Binding Converter={StaticResource NullToVisibility}, ConverterParameter=Inverted}" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ALT TOOLBAR -->
        <Border Grid.Row="1" Grid.ColumnSpan="3" Background="White" BorderBrush="#E5E5E7" BorderThickness="0,1,0,0" Padding="16,12">
            <Grid>
                <TextBlock Text="A4 210×297 mm  •  Sürükleyerek konum, sağ alt köşeden boyut" Foreground="#818285" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="İptal" Style="{StaticResource SecondaryButton}" Width="100" Margin="0,0,8,0" Click="OnCancelClick" />
                    <Button Content="Kaydet" Style="{StaticResource PrimaryButton}" Width="120" Click="OnSaveClick" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

<Window x:Class="AlgowProforma.Views.QuoteEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:m="clr-namespace:AlgowProforma.Models"
        Title="Fiyat Teklifi — Algow Proforma PDF"
        Width="1600" Height="860"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="{StaticResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal">
    <Window.Resources>
        <ObjectDataProvider x:Key="DiscountModes" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="m:DiscountMode" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <!-- Sol: mevcut editör (column 0 default) · Sağ: canlı PDF önizleme paneli -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="330" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="2" Grid.Row="0" Grid.RowSpan="6"
                Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" Padding="10">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="CANLI ÖNİZLEME" Style="{StaticResource MutedText}" FontWeight="SemiBold" FontSize="11" />
                    <TextBlock Text="  ·  yenileniyor…" Style="{StaticResource MutedText}" FontSize="11"
                               Visibility="{Binding IsPreviewLoading, Converter={StaticResource BoolToVis}}" />
                </DockPanel>
                <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Image Source="{Binding PreviewImage}" Stretch="Uniform" Margin="2"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>
            </Grid>
        </Border>

        <!-- Başlık -->
        <TextBlock Grid.Row="0" Text="Fiyat Teklifi" Style="{StaticResource DisplayText}" FontSize="22" FontWeight="Bold" />

        <!-- Müşteri + teklif bilgileri -->
        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="14">
                <StackPanel>
                    <TextBlock Text="MÜŞTERİ" Style="{StaticResource MutedText}" FontWeight="SemiBold" FontSize="11" />
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" ItemsSource="{Binding Customers2}" DisplayMemberPath="DisplayName"
                                  SelectedItem="{Binding SelectedCustomer}" Height="34" />
                        <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="Uygula" Margin="8,0,0,0"
                                Command="{Binding ApplySelectedCustomerCommand}" />
                    </Grid>
                    <TextBlock Margin="0,10,0,0" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"
                               Text="{Binding Quote.CustomerCompany}" />
                    <TextBlock FontSize="12" Foreground="{DynamicResource MutedBrush}" Text="{Binding Quote.CustomerContact}" />
                    <TextBlock FontSize="11" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" Text="{Binding Quote.CustomerAddress}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="14">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Teklif No" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Width="92" />
                        <TextBlock Grid.Column="1" Text="{Binding Quote.QuoteNo, TargetNullValue='(kayıtta atanır)', FallbackValue='(kayıtta atanır)'}" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Geçerlilik (gün)" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Width="92" />
                        <TextBox Grid.Column="1" Style="{StaticResource ModernTextBox}" Text="{Binding Quote.ValidityDays, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Para Birimi" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Width="92" />
                        <ComboBox Grid.Column="1" Height="34" SelectedValue="{Binding Quote.Currency}" SelectedValuePath="Content">
                            <ComboBoxItem Content="TL" />
                            <ComboBoxItem Content="USD" />
                            <ComboBoxItem Content="EUR" />
                        </ComboBox>
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Dil" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Width="92"
                                   ToolTip="EN: PROFORMA INVOICE — tüm PDF etiketleri İngilizce, sayı biçimi 1,234.56" />
                        <ComboBox Grid.Column="1" Height="34" ItemsSource="{Binding LanguageOptions}"
                                  DisplayMemberPath="Label" SelectedValuePath="Id"
                                  SelectedValue="{Binding Quote.Language}" />
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Şablon" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Width="92"
                                   ToolTip="PDF görünümü: Modern (renkli) · Kompakt (dar) · Sade (tek renk, yazıcı dostu)" />
                        <ComboBox Grid.Column="1" Height="34" ItemsSource="{Binding TemplateOptions}"
                                  DisplayMemberPath="Label" SelectedValuePath="Id"
                                  SelectedValue="{Binding Quote.TemplateId}" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Satır ekleme araç çubuğu -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,10">
            <ComboBox Width="320" Height="34" ItemsSource="{Binding PriceBookItems}" DisplayMemberPath="Name"
                      SelectedItem="{Binding SelectedPriceItem}" ToolTip="Fiyat havuzundan ürün" />
            <TextBlock Text="Miktar" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Margin="12,0,6,0" />
            <TextBox Style="{StaticResource ModernTextBox}" Width="64" VerticalAlignment="Center"
                     Text="{Binding AddQuantity, UpdateSourceTrigger=PropertyChanged}" />
            <Button Style="{StaticResource SecondaryButton}" Content="Havuzdan Ekle" Margin="8,0,0,0" Command="{Binding AddFromPriceBookCommand}" />
            <Button Style="{StaticResource SecondaryButton}" Content="Boş Satır" Margin="8,0,0,0" Command="{Binding AddBlankLineCommand}" />
            <Button Style="{StaticResource SecondaryButton}" Content="Satır Sil" Margin="8,0,0,0" Command="{Binding RemoveLineCommand}" />
        </StackPanel>

        <!-- Kalemler — satır ekleme yalnız butonlardan (boş hayalet satır + ondan doğan ghost kalem yok) -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding Quote.Lines}" SelectedItem="{Binding SelectedLine}"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Kod" Binding="{Binding Code}" Width="100" />
                <DataGridTextColumn Header="Ad" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Açıklama" Binding="{Binding Description}" Width="180" />
                <DataGridTextColumn Header="Miktar" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                <DataGridTextColumn Header="Birim" Binding="{Binding Unit}" Width="64" />
                <DataGridTextColumn Header="Birim Fiyat" Binding="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}" Width="92" />
                <DataGridTextColumn Header="İsk %" Binding="{Binding DiscountPct, UpdateSourceTrigger=PropertyChanged}" Width="58" />
                <DataGridTextColumn Header="KDV %" Binding="{Binding VatRate, UpdateSourceTrigger=PropertyChanged}" Width="58" />
                <DataGridTextColumn Header="Tutar" Binding="{Binding LineNet, StringFormat=N2}" Width="100" IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Şartlar + Toplamlar -->
        <Grid Grid.Row="4" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Ödeme Koşulu" Style="{StaticResource MutedText}" />
                <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,8" Text="{Binding Quote.PaymentTerms, UpdateSourceTrigger=PropertyChanged}" />
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Teslim Süresi" Style="{StaticResource MutedText}" />
                        <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,0" Text="{Binding Quote.DeliveryTime, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Teslim Yeri" Style="{StaticResource MutedText}" />
                        <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,0" Text="{Binding Quote.DeliveryPlace, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Kur Notu" Style="{StaticResource MutedText}" />
                        <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,0"
                                 Text="{Binding Quote.ExchangeRateNote, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="TCMB Kurunu Çek"
                            Margin="8,16,0,0" VerticalAlignment="Bottom" Command="{Binding FetchTcmbRatesCommand}"
                            ToolTip="Günün TCMB döviz satış kurlarını (USD/EUR) kur notuna yazar" />
                </Grid>
                <TextBlock Text="Notlar" Style="{StaticResource MutedText}" Margin="0,8,0,0" />
                <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,0" Height="48" AcceptsReturn="True" TextWrapping="Wrap"
                         Text="{Binding Quote.Notes, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="14">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Genel İskonto" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <ComboBox Width="86" Height="30" ItemsSource="{Binding Source={StaticResource DiscountModes}}" SelectedItem="{Binding Quote.DiscountMode}" />
                            <TextBox Style="{StaticResource ModernTextBox}" Width="70" Margin="6,0,0,0" Text="{Binding Quote.DiscountValue, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,2,0,8" />
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Ara Toplam" Foreground="{DynamicResource MutedBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding Quote.Totals.LinesNet, StringFormat=N2}" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" />
                    </Grid>
                    <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="İskonto" Foreground="{DynamicResource MutedBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding Quote.Totals.GeneralDiscount, StringFormat=N2}" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" />
                    </Grid>
                    <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="KDV" Foreground="{DynamicResource MutedBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding Quote.Totals.VatTotal, StringFormat=N2}" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" />
                    </Grid>
                    <Border Background="{StaticResource PrimaryBrush}" Margin="0,8,0,0" Padding="10,8">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="GENEL TOPLAM" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding Quote.Totals.GrandTotal, StringFormat=N2}" Foreground="White" FontWeight="Bold" FontSize="16" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Alt butonlar -->
        <DockPanel Grid.Row="5" Margin="0,16,0,0">
            <TextBlock DockPanel.Dock="Left" Text="{Binding StatusText}" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButton}" Content="Revizyon Oluştur" Margin="0,0,8,0" Command="{Binding CreateRevisionCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Content="Kaydet" Margin="0,0,8,0" Command="{Binding SaveCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Content="Metni Kopyala" Margin="0,0,8,0" Command="{Binding CopyTextCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Content="E-posta Onizle" Margin="0,0,8,0" Command="{Binding PreviewEmailCommand}" />
                <Button Style="{StaticResource PrimaryButton}" Content="PDF Üret &amp; Aç" Command="{Binding GeneratePdfCommand}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>

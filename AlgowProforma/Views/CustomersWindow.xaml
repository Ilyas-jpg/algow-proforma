<Window x:Class="AlgowProforma.Views.CustomersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:m="clr-namespace:AlgowProforma.Models"
        Title="Müşteriler — Algow Proforma PDF"
        Width="1160" Height="720"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="{StaticResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal">
    <Window.Resources>
        <ObjectDataProvider x:Key="SalutationValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="m:Salutation" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Müşteriler" Style="{StaticResource DisplayText}" FontSize="22" FontWeight="Bold" />
            <TextBlock Text="Teklif ve toplu gönderim için müşteri / kişi listesi." Style="{StaticResource MutedText}" Margin="0,2,0,0" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,16,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Style="{StaticResource SecondaryButton}" Content="+ Ekle" Margin="0,0,8,0" Command="{Binding AddItemCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Content="Sil" Margin="0,0,8,0" Command="{Binding DeleteSelectedCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Content="Excel'den İçe Aktar" Margin="0,0,8,0" Command="{Binding ImportExcelCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Content="Excel'e Aktar" Command="{Binding ExportExcelCommand}" />
            </StackPanel>
            <TextBox Grid.Column="1" Style="{StaticResource ModernTextBox}" Width="240" VerticalAlignment="Center"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Firma / kişi / e-posta / telefon / etiket ara" />
        </Grid>

        <DataGrid Grid.Row="2" ItemsSource="{Binding ItemsView}" SelectedItem="{Binding SelectedItem}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Firma" Binding="{Binding CompanyName}" Width="*" />
                <DataGridTextColumn Header="Yetkili" Binding="{Binding ContactName}" Width="160" />
                <DataGridComboBoxColumn Header="Hitap" Width="80"
                                        SelectedItemBinding="{Binding Salutation}"
                                        ItemsSource="{Binding Source={StaticResource SalutationValues}}" />
                <DataGridTextColumn Header="E-posta" Binding="{Binding Email}" Width="200" />
                <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="130" />
                <DataGridTextColumn Header="Adres" Binding="{Binding Address}" Width="200" />
                <DataGridTextColumn Header="Vergi D." Binding="{Binding TaxOffice}" Width="110" />
                <DataGridTextColumn Header="Vergi No" Binding="{Binding TaxNumber}" Width="110" />
                <DataGridTextColumn Header="Etiket" Binding="{Binding Tags}" Width="110" />
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="3" Margin="0,14,0,0">
            <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Content="Kaydet" Command="{Binding SaveCommand}" />
            <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" />
        </DockPanel>
    </Grid>
</Window>

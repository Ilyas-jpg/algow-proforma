<Window x:Class="AlgowProforma.Views.ProductLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AlgowProforma.Converters"
        xmlns:m="clr-namespace:AlgowProforma.Models"
        Title="Ürün Kütüphanesi — Algow Proforma PDF"
        Width="1000" Height="700"
        MinWidth="720" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="{StaticResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">
    <Window.Resources>
        <conv:PathToImageConverter x:Key="PathToImage" />
        <conv:CountToVisibilityConverter x:Key="CountToVisibility" />
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Ürün Kütüphanesi" Style="{StaticResource DisplayText}" FontSize="22" FontWeight="Bold" />
            <TextBlock Text="Kaydedilmiş ürünler — görselleriyle birlikte tüm kataloglarda yeniden kullanılır. Mevcut kataloğa eklemek için bir ürünün 'Kataloğa Ekle'sine tıklayın."
                       Style="{StaticResource MutedText}" Margin="0,2,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Boş durum -->
        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="48"
                Visibility="{Binding Items.Count, Converter={StaticResource CountToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Path Data="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z M3.27 6.96 12 12.01l8.73-5.05 M12 22.08V12"
                      Width="40" Height="40" Stretch="Uniform"
                      Stroke="{DynamicResource MutedBrush}" StrokeThickness="1.5" Fill="Transparent" />
                <TextBlock Text="Kütüphane boş" Style="{StaticResource BodyText}" FontWeight="SemiBold" Margin="0,16,0,4" HorizontalAlignment="Center" />
                <TextBlock Text="Bir katalogda ürün oluşturup 'Kütüphaneye Kaydet' ile buraya ekleyin — sonra tüm kataloglarda tekrar kullanın."
                           Style="{StaticResource MutedText}" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="380" TextAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Ürün kartları -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding Items.Count, Converter={StaticResource CountToVisibility}, ConverterParameter=Inverted}">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type m:Product}">
                        <Border Width="200" Margin="0,0,14,14" Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="12">
                            <StackPanel>
                                <Border Height="140" Background="{DynamicResource BackgroundBrush}" CornerRadius="6">
                                    <Image Source="{Binding ImagePath, Converter={StaticResource PathToImage}}"
                                           Stretch="Uniform" Margin="8" RenderOptions.BitmapScalingMode="HighQuality" />
                                </Border>
                                <TextBlock Text="{Binding Name}" Style="{StaticResource BodyText}" FontWeight="SemiBold"
                                           Margin="0,10,0,0" TextTrimming="CharacterEllipsis" />
                                <TextBlock Margin="0,3,0,0" Style="{StaticResource MutedText}" TextTrimming="CharacterEllipsis">
                                    <Run Text="{Binding Code, Mode=OneWay}" />
                                    <Run Text="  ·  " />
                                    <Run Text="{Binding Price, Mode=OneWay}" />
                                    <Run Text=" " />
                                    <Run Text="{Binding Currency, Mode=OneWay}" />
                                </TextBlock>
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource PrimaryButton}" Content="Kataloğa Ekle"
                                            Padding="10,7" FontSize="12"
                                            Command="{Binding DataContext.AddToCatalogCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                    <Button Grid.Column="1" Style="{StaticResource DangerIconButton}" Margin="6,0,0,0"
                                            Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" ToolTip="Kütüphaneden sil">
                                        <Path Data="M3 6h18 M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2 M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6 M10 11v6 M14 11v6"
                                              Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.6" Fill="Transparent" />
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="0,16,0,0">
            <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}" Content="Kapat" Click="OnClose" />
            <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" />
        </DockPanel>
    </Grid>
</Window>

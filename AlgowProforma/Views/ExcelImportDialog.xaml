<Window x:Class="AlgowProforma.Views.ExcelImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AlgowProforma.Converters"
        Width="900" Height="640"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        FontFamily="{StaticResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

    <Window.Resources>
        <conv:PathToImageConverter x:Key="PathToImage" />
        <conv:ExcelRowToImageConverter x:Key="RowToImage" />
    </Window.Resources>

    <Border Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.16" BlurRadius="24" ShadowDepth="2" Direction="270" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Height="48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="Transparent" MouseLeftButtonDown="OnDragMove">
                    <TextBlock Text="Excel'den İçe Aktar" Style="{StaticResource DisplayText}"
                               FontSize="14" Margin="22,0,0,0" VerticalAlignment="Center" />
                </Border>
                <Button Grid.Column="1" Style="{StaticResource IconButton}" Width="32" Height="32"
                        Margin="0,8,12,0" Click="OnCancel" ToolTip="Kapat" IsCancel="True">
                    <Path Data="M18 6 6 18 M6 6l12 12" Width="14" Height="14" Stretch="Uniform"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.6" Fill="Transparent" />
                </Button>
            </Grid>

            <!-- Options -->
            <StackPanel Grid.Row="1" Margin="22,0,22,12">
                <TextBlock Text="Excel dosyasındaki ürünleri (kod, açıklama, fiyat) ve gömülü görselleri otomatik olarak içe aktarır."
                           Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,12" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PathBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                    <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Content="Dosya Seç"
                            Click="OnBrowseFile" />
                </Grid>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="Sayfa" Style="{StaticResource LabelText}" />
                        <ComboBox x:Name="SheetCombo" Style="{StaticResource ModernComboBox}"
                                  SelectionChanged="OnSheetChanged" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Text="Kod sütunu" Style="{StaticResource LabelText}" />
                        <!-- Eşleme değişince önizleme ANINDA yenilenir — eski eşlemeyle içe aktarma tuzağı kapandı -->
                        <ComboBox x:Name="CodeCombo" Style="{StaticResource ModernComboBox}"
                                  SelectionChanged="OnMappingChanged" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="4">
                        <TextBlock Text="Açıklama sütunu" Style="{StaticResource LabelText}" />
                        <ComboBox x:Name="NameCombo" Style="{StaticResource ModernComboBox}"
                                  SelectionChanged="OnMappingChanged" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,10,0,0">
                        <TextBlock Text="Fiyat sütunu (ops.)" Style="{StaticResource LabelText}" />
                        <ComboBox x:Name="PriceCombo" Style="{StaticResource ModernComboBox}"
                                  SelectionChanged="OnMappingChanged" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,10,0,0">
                        <TextBlock Text="Kategori sütunu (ops.)" Style="{StaticResource LabelText}" />
                        <ComboBox x:Name="CategoryCombo" Style="{StaticResource ModernComboBox}"
                                  SelectionChanged="OnMappingChanged"
                                  ToolTip="Katalog bölümü — Sayfa Düzeni'nde kategori sayfaları açıksa her kategori kendi başlık sayfasıyla başlar" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="4" Margin="0,10,0,0">
                        <TextBlock Text="Görsel kaynağı" Style="{StaticResource LabelText}" />
                        <ComboBox x:Name="ImageCombo" Style="{StaticResource ModernComboBox}"
                                  SelectionChanged="OnMappingChanged" />
                    </StackPanel>
                </Grid>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <CheckBox x:Name="HeaderCheck" Style="{StaticResource ModernCheckBox}"
                              Content="İlk satır başlık" IsChecked="True"
                              Checked="OnPreviewRequested" Unchecked="OnPreviewRequested"
                              VerticalAlignment="Center" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Birim:" Style="{StaticResource LabelText}" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <ComboBox x:Name="CurrencyCombo" Style="{StaticResource ModernComboBox}" Width="100">
                            <ComboBoxItem Content="TL" IsSelected="True" />
                            <ComboBoxItem Content="USD" />
                            <ComboBoxItem Content="EUR" />
                        </ComboBox>
                    </StackPanel>

                    <Button Grid.Column="2" Style="{StaticResource SecondaryButton}"
                            Content="Önizlemeyi Yenile" Click="OnPreviewRequested" />
                </Grid>
            </StackPanel>

            <!-- Preview list -->
            <Border Grid.Row="2" Margin="22,0,22,12"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <TextBlock x:Name="EmptyHint"
                               Text="Bir Excel dosyası seçin, ardından sütun eşlemesi yapın."
                               Style="{StaticResource MutedText}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <ListBox x:Name="PreviewList" BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12" BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="56" Height="56"
                                                Background="{DynamicResource SurfaceBrush}" CornerRadius="6">
                                            <!-- Lazy-extract: görsel henüz diskte olmayabilir; converter bellekteki baytlardan da okur -->
                                            <Image Source="{Binding ., Converter={StaticResource RowToImage}}"
                                                   Stretch="Uniform" Margin="4" />
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding Code}"
                                                   Style="{StaticResource BodyText}" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       Style="{StaticResource BodyText}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Category}"
                                                       Style="{StaticResource MutedText}" FontSize="11"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="4" Text="{Binding Price, StringFormat=N2}"
                                                   Style="{StaticResource MutedText}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="22,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusText" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource SecondaryButton}" Content="İptal"
                                Margin="0,0,8,0" Click="OnCancel" IsCancel="True" />
                        <Button x:Name="ImportBtn" Style="{StaticResource PrimaryButton}" Content="İçe Aktar"
                                Click="OnImport" IsDefault="True" IsEnabled="False" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

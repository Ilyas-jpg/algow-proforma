<Window x:Class="AlgowProforma.Views.ImageCropperDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="820" Height="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="{StaticResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

    <Window.Resources>
        <Style x:Key="CropHandle" TargetType="Thumb">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="3" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.16" BlurRadius="24" ShadowDepth="2" Direction="270" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Height="48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="Transparent" MouseLeftButtonDown="OnDragMove">
                    <TextBlock x:Name="TitleText" Text="Görseli Kırp" Style="{StaticResource DisplayText}"
                               FontSize="14" Margin="22,0,0,0" VerticalAlignment="Center" />
                </Border>
                <Button Grid.Column="1" Style="{StaticResource IconButton}" Width="32" Height="32"
                        Margin="0,8,12,0" Click="OnCancel" ToolTip="Kapat" IsCancel="True">
                    <Path Data="M18 6 6 18 M6 6l12 12" Width="14" Height="14" Stretch="Uniform"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.6" Fill="Transparent" />
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="22,0,22,12" VerticalAlignment="Center">
                <TextBlock Text="En-boy oranı:" Style="{StaticResource LabelText}" Margin="0,0,12,0"
                           VerticalAlignment="Center" />
                <Button Style="{StaticResource SecondaryButton}" Content="Serbest" Margin="0,0,6,0"
                        Click="OnAspectFree" Padding="12,6" />
                <Button Style="{StaticResource SecondaryButton}" Content="1:1" Margin="0,0,6,0"
                        Click="OnAspectSquare" Padding="12,6" />
                <Button Style="{StaticResource SecondaryButton}" Content="4:3" Margin="0,0,6,0"
                        Click="OnAspect43" Padding="12,6" />
                <Button Style="{StaticResource SecondaryButton}" Content="16:9" Margin="0,0,6,0"
                        Click="OnAspect169" Padding="12,6" />
                <Button Style="{StaticResource SecondaryButton}" Content="Tümü" Margin="16,0,0,0"
                        Click="OnResetCrop" Padding="12,6" ToolTip="Tüm görseli seç" />
            </StackPanel>

            <Border Grid.Row="2" Margin="22,0,22,16" Background="#1A000000" CornerRadius="8" ClipToBounds="True">
                <Grid x:Name="WorkArea" SizeChanged="OnWorkAreaSizeChanged" Background="Transparent">
                    <Image x:Name="SourceImage" Stretch="Uniform" />
                    <Canvas x:Name="OverlayCanvas" Background="Transparent">
                        <Rectangle x:Name="ShadeTop" Fill="#88000000" IsHitTestVisible="False" />
                        <Rectangle x:Name="ShadeBottom" Fill="#88000000" IsHitTestVisible="False" />
                        <Rectangle x:Name="ShadeLeft" Fill="#88000000" IsHitTestVisible="False" />
                        <Rectangle x:Name="ShadeRight" Fill="#88000000" IsHitTestVisible="False" />
                        <Rectangle x:Name="CropRect" Stroke="White" StrokeThickness="2" Fill="Transparent"
                                   Cursor="SizeAll" MouseLeftButtonDown="OnCropMouseDown"
                                   MouseLeftButtonUp="OnCropMouseUp" MouseMove="OnCropMouseMove" />
                        <Thumb x:Name="HandleNW" Style="{StaticResource CropHandle}" Width="14" Height="14"
                               Cursor="SizeNWSE" DragDelta="OnHandleDragNW" />
                        <Thumb x:Name="HandleNE" Style="{StaticResource CropHandle}" Width="14" Height="14"
                               Cursor="SizeNESW" DragDelta="OnHandleDragNE" />
                        <Thumb x:Name="HandleSW" Style="{StaticResource CropHandle}" Width="14" Height="14"
                               Cursor="SizeNESW" DragDelta="OnHandleDragSW" />
                        <Thumb x:Name="HandleSE" Style="{StaticResource CropHandle}" Width="14" Height="14"
                               Cursor="SizeNWSE" DragDelta="OnHandleDragSE" />
                    </Canvas>
                </Grid>
            </Border>

            <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="22,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource MutedText}" VerticalAlignment="Center">
                        <Run Text="Köşelerden boyutlandır · ortadan sürükleyerek konumlandır · " />
                        <Run x:Name="DimsText" Text="" />
                    </TextBlock>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource SecondaryButton}" Content="İptal"
                                Margin="0,0,8,0" Click="OnCancel" IsCancel="True" />
                        <Button Style="{StaticResource PrimaryButton}" Content="Kırp ve Kaydet"
                                Click="OnSave" IsDefault="True" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

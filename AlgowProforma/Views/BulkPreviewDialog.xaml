<Window x:Class="AlgowProforma.Views.BulkPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="640" SizeToContent="Height"
        MaxHeight="760"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="{StaticResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

    <Border Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.16" BlurRadius="24" ShadowDepth="2" Direction="270" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Height="48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="Transparent" MouseLeftButtonDown="OnDragMove">
                    <TextBlock Text="Gönderim Önizlemesi" Style="{StaticResource DisplayText}"
                               FontSize="14" Margin="22,0,0,0" VerticalAlignment="Center" />
                </Border>
                <Button Grid.Column="1" Style="{StaticResource IconButton}" Width="32" Height="32"
                        Margin="0,8,12,0" Click="OnCancel" ToolTip="Kapat" IsCancel="True">
                    <Path Data="M18 6 6 18 M6 6l12 12" Width="14" Height="14" Stretch="Uniform"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.6" Fill="Transparent" />
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" Margin="22,0,22,16">
                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" Padding="14" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Teklif" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,6" />
                        <TextBlock x:Name="QuoteText" Grid.Row="0" Grid.Column="1" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="1" Text="Kanal" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,6" />
                        <TextBlock x:Name="ProviderText" Grid.Row="1" Grid.Column="1" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="2" Text="Alıcı sayısı" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,6" />
                        <TextBlock x:Name="CountText" Grid.Row="2" Grid.Column="1" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="3" Text="Örnek alıcı" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,6" />
                        <TextBlock x:Name="SampleRecipientText" Grid.Row="3" Grid.Column="1" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="4" Text="Ek (PDF)" Foreground="{DynamicResource MutedBrush}" />
                        <DockPanel Grid.Row="4" Grid.Column="1">
                            <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}" Content="Örnek PDF'i Aç"
                                    Click="OnOpenSamplePdf"
                                    ToolTip="İlk alıcının adına üretilmiş GERÇEK PDF'i açar — gönderilecek ekin birebir aynısı" />
                            <TextBlock x:Name="AttachmentText" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                    </Grid>
                </Border>

                <TextBlock Text="Konu" Style="{StaticResource MutedText}" />
                <TextBox x:Name="SubjectBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True" Margin="0,2,0,10" />

                <TextBlock Text="E-posta gövdesi (örnek alıcıya kişiselleştirilmiş)" Style="{StaticResource MutedText}" />
                <TextBox x:Name="BodyBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True" Margin="0,2,0,0"
                         Height="200" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
            </StackPanel>

            <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="22,16">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource SecondaryButton}" Content="Vazgeç"
                            Margin="0,0,8,0" Click="OnCancel" IsCancel="True" />
                    <Button Style="{StaticResource PrimaryButton}" Content="Gönderimi Başlat"
                            Click="OnConfirm" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>

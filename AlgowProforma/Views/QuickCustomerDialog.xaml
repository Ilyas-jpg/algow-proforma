<Window x:Class="AlgowProforma.Views.QuickCustomerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="480" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="{StaticResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

    <Border Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.16" BlurRadius="24" ShadowDepth="2" Direction="270" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Height="48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="Transparent" MouseLeftButtonDown="OnDragMove">
                    <TextBlock Text="Hızlı Müşteri Ekle" Style="{StaticResource DisplayText}"
                               FontSize="14" Margin="22,0,0,0" VerticalAlignment="Center" />
                </Border>
                <Button Grid.Column="1" Style="{StaticResource IconButton}" Width="32" Height="32"
                        Margin="0,8,12,0" Click="OnCancel" ToolTip="Kapat" IsCancel="True">
                    <Path Data="M18 6 6 18 M6 6l12 12" Width="14" Height="14" Stretch="Uniform"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.6" Fill="Transparent" />
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" Margin="22,0,22,16">
                <TextBlock Text="Müşteri CRM listesine kaydedilir ve bu teklife uygulanır. Detayları (adres, vergi) sonradan Müşteriler penceresinden tamamlayabilirsiniz."
                           Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,14" />

                <TextBlock Text="Firma *" Style="{StaticResource LabelText}" />
                <TextBox x:Name="CompanyBox" Style="{StaticResource ModernTextBox}" Margin="0,2,0,10"
                         TextChanged="OnFieldChanged" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Yetkili" Style="{StaticResource LabelText}" />
                        <TextBox x:Name="ContactBox" Style="{StaticResource ModernTextBox}" Margin="0,2,0,10" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Hitap" Style="{StaticResource LabelText}" />
                        <ComboBox x:Name="SalutationCombo" Style="{StaticResource ModernComboBox}" Margin="0,2,0,10">
                            <ComboBoxItem Content="—" IsSelected="True" />
                            <ComboBoxItem Content="Bey" />
                            <ComboBoxItem Content="Hanım" />
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="E-posta" Style="{StaticResource LabelText}" />
                        <TextBox x:Name="EmailBox" Style="{StaticResource ModernTextBox}" Margin="0,2,0,0"
                                 TextChanged="OnFieldChanged" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Telefon" Style="{StaticResource LabelText}" />
                        <TextBox x:Name="PhoneBox" Style="{StaticResource ModernTextBox}" Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>

                <TextBlock x:Name="ValidationText" Style="{StaticResource MutedText}" Foreground="#D03050"
                           Margin="0,8,0,0" Visibility="Collapsed" />
            </StackPanel>

            <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="22,16">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource SecondaryButton}" Content="İptal"
                            Margin="0,0,8,0" Click="OnCancel" IsCancel="True" />
                    <Button x:Name="SaveBtn" Style="{StaticResource PrimaryButton}" Content="Kaydet ve Uygula"
                            Click="OnSave" IsDefault="True" IsEnabled="False" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>

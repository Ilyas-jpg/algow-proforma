<Window x:Class="AlgowProforma.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ayarlar — Algow Proforma PDF"
        Width="820" Height="860"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="{StaticResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Ayarlar" Style="{StaticResource DisplayText}" FontSize="22" FontWeight="Bold" Margin="0,0,0,12" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- GOOGLE / GMAIL -->
                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Google Workspace / Gmail" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" FontSize="14" Margin="0,0,0,10" />
                        <TextBlock Text="{Binding GoogleLoginStatus}" Style="{StaticResource MutedText}" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding GmailStatus}" Style="{StaticResource MutedText}" Margin="0,0,0,10" />

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Google Client ID" Style="{StaticResource MutedText}" />
                                <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,0"
                                         Text="{Binding Settings.Google.ClientId, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Google Client Secret" Style="{StaticResource MutedText}" />
                                <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,0"
                                         Text="{Binding Settings.Google.ClientSecret, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Login Redirect URI" Style="{StaticResource MutedText}" />
                                <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,0"
                                         Text="{Binding Settings.Google.AuthRedirectUri, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Gmail Redirect URI" Style="{StaticResource MutedText}" />
                                <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,0"
                                         Text="{Binding Settings.Google.GmailRedirectUri, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Izin verilen domainler (opsiyonel, virgulle ayrilir)" Style="{StaticResource MutedText}" Margin="0,10,0,0" />
                        <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,0"
                                 Text="{Binding Settings.Google.AllowedDomains, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Not: GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET env degiskenleri ayar ekranindaki degerlerin onune gecer." Style="{StaticResource MutedText}" FontSize="11" Margin="0,8,0,0" />

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Style="{StaticResource SecondaryButton}" Content="Continue with Google" Click="OnGoogleSignIn" />
                            <Button Style="{StaticResource PrimaryButton}" Content="Connect Gmail / Workspace" Margin="8,0,0,0" Click="OnConnectGmail" />
                            <Button Style="{StaticResource SecondaryButton}" Content="Disconnect Gmail" Margin="8,0,0,0" Click="OnDisconnectGmail" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- MAIL HESABI -->
                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Mail Hesabı — Google Workspace SMTP" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" FontSize="14" Margin="0,0,0,12" />

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="SMTP Sunucu" Style="{StaticResource MutedText}" />
                                <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,0" Text="{Binding Settings.Mail.SmtpHost, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Port" Style="{StaticResource MutedText}" />
                                <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,0" Text="{Binding Settings.Mail.SmtpPort, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Gönderen Adı" Style="{StaticResource MutedText}" />
                                <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,0" Text="{Binding Settings.Mail.FromName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Gönderen E-posta" Style="{StaticResource MutedText}" />
                                <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,0" Text="{Binding Settings.Mail.FromEmail, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Kullanıcı Adı (genelde gönderen e-posta)" Style="{StaticResource MutedText}" Margin="0,10,0,0" />
                        <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,0" Text="{Binding Settings.Mail.Username, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Uygulama Şifresi (App Password)" Style="{StaticResource MutedText}" Margin="0,10,0,0" />
                        <Grid Margin="0,2,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <PasswordBox x:Name="PwBox" Grid.Column="0" Height="34" Padding="8,0" VerticalContentAlignment="Center"
                                         Background="{DynamicResource ElevatedSurfaceBrush}" Foreground="{DynamicResource TextBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" />
                            <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="Şifreyi Kaydet" Margin="8,0,0,0" Click="OnSavePassword" />
                            <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Content="Sil" Margin="8,0,0,0" Click="OnClearPassword" />
                        </Grid>
                        <TextBlock Text="{Binding HasStoredPassword, StringFormat='Kayıtlı şifre: {0}'}" Style="{StaticResource MutedText}" FontSize="11" Margin="0,4,0,0" />

                        <CheckBox Content="Her gönderimin kopyasını kendime gönder (BCC arşiv)" Margin="0,12,0,0"
                                  Foreground="{DynamicResource TextBrush}" IsChecked="{Binding Settings.Mail.BccSelf}" />

                        <TextBlock Text="Dakikada en fazla mail (hız sınırı)" Style="{StaticResource MutedText}" Margin="0,10,0,0" />
                        <TextBox Style="{StaticResource ModernTextBox}" Width="80" HorizontalAlignment="Left" Margin="0,2,0,0"
                                 Text="{Binding Settings.Mail.MaxPerMinute, UpdateSourceTrigger=PropertyChanged}" />

                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,14,0,12" />
                        <TextBlock Text="Test E-postası" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource ModernTextBox}" Text="{Binding TestEmail, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Content="Test Gönder" Margin="8,0,0,0" Click="OnTestSend" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- E-POSTA ŞABLONU -->
                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="16">
                    <StackPanel>
                        <TextBlock Text="E-posta Şablonu" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" FontSize="14" Margin="0,0,0,4" />
                        <TextBlock Text="{}{ad} = kişi adı yer tutucu. Teklif PDF eki otomatik eklenir." Style="{StaticResource MutedText}" FontSize="11" Margin="0,0,0,12" />

                        <TextBlock Text="Konu" Style="{StaticResource MutedText}" />
                        <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,8" Text="{Binding Settings.EmailTemplate.Subject, UpdateSourceTrigger=PropertyChanged}" />

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Selam (Bey)" Style="{StaticResource MutedText}" />
                                <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,0" Text="{Binding Settings.EmailTemplate.GreetingBey, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Selam (Hanım)" Style="{StaticResource MutedText}" />
                                <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,0" Text="{Binding Settings.EmailTemplate.GreetingHanim, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Selam (Genel)" Style="{StaticResource MutedText}" />
                                <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,0" Text="{Binding Settings.EmailTemplate.GreetingNeutral, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Gövde" Style="{StaticResource MutedText}" Margin="0,10,0,0" />
                        <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,0" Height="46" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding Settings.EmailTemplate.Body, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Kapanış" Style="{StaticResource MutedText}" Margin="0,10,0,0" />
                        <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,0" Text="{Binding Settings.EmailTemplate.Closing, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="İmza" Style="{StaticResource MutedText}" Margin="0,10,0,0" />
                        <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,0" Height="84" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding Settings.EmailTemplate.Signature, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Ek dosya adı kalıbı  ({musteri}, {tarih})" Style="{StaticResource MutedText}" Margin="0,10,0,0" />
                        <TextBox Style="{StaticResource ModernTextBox}" Margin="0,2,0,0" Text="{Binding Settings.EmailTemplate.AttachmentPattern, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="0,14,0,0">
            <TextBlock DockPanel.Dock="Left" Text="{Binding StatusText}" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" TextWrapping="Wrap" />
            <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Content="Kaydet" Command="{Binding SaveCommand}" HorizontalAlignment="Right" />
        </DockPanel>
    </Grid>
</Window>

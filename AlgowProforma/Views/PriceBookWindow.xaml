<Window x:Class="AlgowProforma.Views.PriceBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fiyat Listesi — Algow Proforma PDF"
        Width="1120" Height="720"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="{StaticResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Fiyat Listesi" Style="{StaticResource DisplayText}" FontSize="22" FontWeight="Bold" />
            <TextBlock Text="Tekliflerde kullanılacak ürün ve birim fiyat havuzu (KDV hariç)." Style="{StaticResource MutedText}" Margin="0,2,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,16,0,12">
            <Button Style="{StaticResource SecondaryButton}" Content="+ Ekle" Margin="0,0,8,0" Command="{Binding AddItemCommand}" />
            <Button Style="{StaticResource SecondaryButton}" Content="Sil" Margin="0,0,8,0" Command="{Binding DeleteSelectedCommand}" />
            <Button Style="{StaticResource SecondaryButton}" Content="Excel'den İçe Aktar" Margin="0,0,8,0" Command="{Binding ImportExcelCommand}" />
            <Button Style="{StaticResource SecondaryButton}" Content="Excel'e Aktar" Margin="0,0,20,0" Command="{Binding ExportExcelCommand}" />
            <TextBlock Text="Toplu %" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
            <TextBox Style="{StaticResource ModernTextBox}" Width="64" VerticalAlignment="Center"
                     Text="{Binding BulkPercent, UpdateSourceTrigger=PropertyChanged}" />
            <Button Style="{StaticResource SecondaryButton}" Content="Tümüne Uygula" Margin="6,0,0,0" Command="{Binding ApplyBulkCommand}"
                    ToolTip="Tüm listeye yüzde zam (+10) / indirim (-5)" />
            <Button Style="{StaticResource SecondaryButton}" Content="Seçiliye Uygula" Margin="6,0,0,0"
                    Command="{Binding ApplyBulkSelectedCommand}"
                    CommandParameter="{Binding SelectedItems, ElementName=PriceGrid}"
                    ToolTip="Yalnız seçili satırlara uygular — Ctrl/Shift ile çoklu satır seçebilirsiniz" />
        </StackPanel>

        <DataGrid x:Name="PriceGrid" Grid.Row="2" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}"
                  SelectionMode="Extended">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Kod" Binding="{Binding Code}" Width="120" />
                <DataGridTextColumn Header="Ad" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Açıklama" Binding="{Binding Description}" Width="200" />
                <DataGridTextColumn Header="Birim" Binding="{Binding Unit}" Width="72" />
                <DataGridTextColumn Header="Birim Fiyat" Binding="{Binding UnitPrice}" Width="110" />
                <DataGridTextColumn Header="KDV %" Binding="{Binding VatRate}" Width="64" />
                <DataGridTextColumn Header="Döviz" Binding="{Binding Currency}" Width="64" />
                <DataGridTextColumn Header="Kategori" Binding="{Binding Category}" Width="130" />
                <DataGridCheckBoxColumn Header="Aktif" Binding="{Binding IsActive}" Width="52" />
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="3" Margin="0,14,0,0">
            <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Content="Kaydet" Command="{Binding SaveCommand}" />
            <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" />
        </DockPanel>
    </Grid>
</Window>

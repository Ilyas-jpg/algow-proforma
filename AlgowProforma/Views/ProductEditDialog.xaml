<Window x:Class="AlgowProforma.Views.ProductEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AlgowProforma.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Width="780" Height="820"
        MaxWidth="{x:Static SystemParameters.MaximizedPrimaryScreenWidth}"
        MaxHeight="{x:Static SystemParameters.MaximizedPrimaryScreenHeight}"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="{StaticResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

    <Window.Resources>
        <conv:PathToImageConverter x:Key="PathToImage" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibility" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <x:Array x:Key="CurrencyOptions" Type="sys:String">
            <sys:String>TL</sys:String>
            <sys:String>USD</sys:String>
            <sys:String>EUR</sys:String>
        </x:Array>

        <Geometry x:Key="TrashGeo">M3 6h18 M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2 m3 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6</Geometry>
    </Window.Resources>

    <Border Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.16" BlurRadius="24" ShadowDepth="2" Direction="270" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Height="48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="Transparent" MouseLeftButtonDown="OnDragMove">
                    <TextBlock x:Name="TitleText" Style="{StaticResource DisplayText}"
                               FontSize="14" Margin="22,0,0,0" VerticalAlignment="Center" />
                </Border>
                <Button Grid.Column="1" Style="{StaticResource IconButton}" Width="32" Height="32"
                        Margin="0,8,12,0" Click="OnCancel" ToolTip="Kapat">
                    <Path Data="M18 6 6 18 M6 6l12 12" Width="14" Height="14" Stretch="Uniform"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.6" Fill="Transparent" />
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0">
                <StackPanel>

                    <Grid Margin="22,4,22,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Top">
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Width="180" Height="180">
                                <Grid>
                                    <Image Source="{Binding ImagePath, Converter={StaticResource PathToImage}}"
                                           Stretch="Uniform" Margin="14"
                                           Visibility="{Binding ImagePath, Converter={StaticResource NullToVisibility}}" />
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Visibility="{Binding ImagePath, Converter={StaticResource NullToVisibility}, ConverterParameter=Inverted}">
                                        <Path Data="M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z M9 9a2 2 0 1 1 0-4 2 2 0 0 1 0 4z M21 15l-5-5L5 21"
                                              Width="28" Height="28" Stretch="Uniform"
                                              Stroke="{DynamicResource MutedBrush}" StrokeThickness="1.5" Fill="Transparent" />
                                        <TextBlock Text="Görsel yok" Style="{StaticResource MutedText}"
                                                   Margin="0,8,0,0" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Button Style="{StaticResource SecondaryButton}" Content="Görsel Seç"
                                    Margin="0,12,0,0" HorizontalAlignment="Stretch" Click="OnBrowseImage" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Top">
                            <TextBlock Text="Ürün Adı (zorunlu)" Style="{StaticResource LabelText}" />
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="Ürün Kodu" Style="{StaticResource LabelText}" Margin="0,16,0,6" />
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="Kategori (katalog bölümü — örn. Küresel Vanalar)" Style="{StaticResource LabelText}" Margin="0,16,0,6" />
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Sayfa Düzeni'nde 'Kategori başlık sayfaları' açıksa aynı kategorideki ürünler PDF'te kendi bölümünde toplanır" />

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="92" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Fiyat" Style="{StaticResource LabelText}" />
                                    <TextBox Style="{StaticResource ModernTextBox}"
                                             Text="{Binding Price, UpdateSourceTrigger=LostFocus, StringFormat=N2}"
                                             PreviewTextInput="OnPriceTextInput" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Birim" Style="{StaticResource LabelText}" />
                                    <ComboBox Style="{StaticResource ModernComboBox}"
                                              ItemsSource="{StaticResource CurrencyOptions}"
                                              SelectedItem="{Binding Currency}" />
                                </StackPanel>
                            </Grid>

                            <Border Margin="0,20,0,0" Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="12">
                                <StackPanel>
                                    <CheckBox Style="{StaticResource ModernCheckBox}"
                                              IsChecked="{Binding IsFeatured}"
                                              Content="Bu ürünü öne çıkar" />
                                    <TextBlock Text="PDF'te 2 sütun genişliğinde büyük kart olarak gösterilir."
                                               Style="{StaticResource MutedText}" Margin="28,4,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Border Margin="22,0,22,12" Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="12">
                        <StackPanel>
                            <CheckBox x:Name="TableModeCheck" Style="{StaticResource ModernCheckBox}"
                                      IsChecked="{Binding HasTable}"
                                      Content="Tablo modu (özellik tablosu)"
                                      Checked="OnTableModeChecked" />
                            <TextBlock Text="PDF'te bu ürün; başlık, özellik satırları ve veri tablosundan oluşan tam genişlik bir blok olarak basılır."
                                       Style="{StaticResource MutedText}" Margin="28,4,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="TableEditorBox"
                            Margin="22,0,22,18"
                            Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="8" Padding="14"
                            Visibility="{Binding HasTable, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel x:Name="TableEditorPanel">
                            <TextBlock Text="Tablo Başlığı (boş bırakılırsa ürün adı kullanılır)" Style="{StaticResource LabelText}" />
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Table.Title, UpdateSourceTrigger=PropertyChanged}" />

                            <Grid Margin="0,18,0,6">
                                <TextBlock Text="Özellik Satırları" Style="{StaticResource LabelText}" Margin="0" HorizontalAlignment="Left" VerticalAlignment="Center" />
                                <Button HorizontalAlignment="Right" Style="{StaticResource SecondaryButton}"
                                        Content="+ Özellik" Click="OnAddSpec" Padding="12,5" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding Table.Specs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3,0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="170" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="32" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Style="{StaticResource ModernTextBox}"
                                                     Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBox Grid.Column="2" Style="{StaticResource ModernTextBox}"
                                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Grid.Column="4" Style="{StaticResource IconButton}"
                                                    Width="32" Height="32" Click="OnRemoveSpec" ToolTip="Sil">
                                                <Path Data="{StaticResource TrashGeo}" Width="14" Height="14" Stretch="Uniform"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      StrokeThickness="1.5" Fill="Transparent" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid Margin="0,18,0,6">
                                <TextBlock Text="Sütunlar &amp; Satırlar" Style="{StaticResource LabelText}" Margin="0" HorizontalAlignment="Left" VerticalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Style="{StaticResource SecondaryButton}"
                                            Content="+ Sütun" Click="OnAddColumn" Padding="12,5" Margin="0,0,6,0" />
                                    <Button Style="{StaticResource SecondaryButton}"
                                            Content="+ Satır" Click="OnAddRow" Padding="12,5" />
                                </StackPanel>
                            </Grid>

                            <Border Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="8">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                              MaxHeight="320">
                                    <StackPanel>
                                        <ItemsControl ItemsSource="{Binding Table.Columns}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Width="105" Margin="0,0,4,4">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBox Grid.Row="0" Style="{StaticResource ModernTextBox}"
                                                                 FontWeight="SemiBold" Padding="8,8"
                                                                 Text="{Binding Header, UpdateSourceTrigger=PropertyChanged}" />
                                                        <Button Grid.Row="1" Style="{StaticResource SecondaryButton}"
                                                                Content="Sütunu sil" Click="OnRemoveColumn"
                                                                Padding="0,4" FontSize="11" Margin="0,4,0,0" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <ItemsControl ItemsSource="{Binding Table.Rows}" Margin="0,4,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <ItemsControl ItemsSource="{Binding Cells}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBox Width="105" Margin="0,0,4,0" Padding="8,8"
                                                                             Style="{StaticResource ModernTextBox}"
                                                                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <Button Style="{StaticResource IconButton}"
                                                                Width="32" Height="32" Click="OnRemoveRow" ToolTip="Satır sil"
                                                                Margin="2,0,0,0">
                                                            <Path Data="{StaticResource TrashGeo}" Width="14" Height="14" Stretch="Uniform"
                                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                  StrokeThickness="1.5" Fill="Transparent" />
                                                        </Button>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="22,16">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource SecondaryButton}" Content="İptal"
                            Margin="0,0,8,0" Click="OnCancel" IsCancel="True" />
                    <Button x:Name="SaveBtn" Style="{StaticResource PrimaryButton}" Content="Kaydet"
                            Click="OnSave" IsDefault="True" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>

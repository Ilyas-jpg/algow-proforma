<Window x:Class="AlgowProforma.Views.SendHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gönderim Geçmişi — Algow Proforma PDF"
        Width="1150" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="{StaticResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Gönderim Geçmişi" Style="{StaticResource DisplayText}" FontSize="22" FontWeight="Bold" />
            <TextBlock x:Name="SummaryText" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBox x:Name="SearchBox" Style="{StaticResource ModernTextBox}" Width="280" VerticalAlignment="Center"
                     TextChanged="OnFilterChanged"
                     ToolTip="Teklif no, alıcı e-postası, firma veya konuya göre süz" />
            <CheckBox x:Name="OnlyFailedCheck" Style="{StaticResource ModernCheckBox}" Content="Yalnız başarısızlar"
                      Margin="14,0,0,0" VerticalAlignment="Center"
                      Checked="OnFilterChanged" Unchecked="OnFilterChanged" />
            <Button Style="{StaticResource SecondaryButton}" Content="Yenile" Margin="14,0,0,0" Click="OnRefresh" />
        </StackPanel>

        <DataGrid x:Name="LogGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tarih" Binding="{Binding SentAt, StringFormat=dd.MM.yyyy HH:mm}" Width="120" />
                <DataGridTextColumn Header="Teklif No" Binding="{Binding QuoteNo}" Width="130" />
                <DataGridTextColumn Header="Alıcı" Binding="{Binding ToEmail}" Width="200" />
                <DataGridTextColumn Header="Firma" Binding="{Binding RecipientCompany}" Width="*" />
                <DataGridTextColumn Header="Konu" Binding="{Binding Subject}" Width="180" />
                <DataGridTextColumn Header="Kanal" Binding="{Binding Provider}" Width="64" />
                <DataGridTemplateColumn Header="Sonuç" Width="76">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="✗ Hata" />
                                        <Setter Property="Foreground" Value="#D03050" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Success}" Value="True">
                                                <Setter Property="Text" Value="✓" />
                                                <Setter Property="Foreground" Value="#2E8B57" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Hata" Binding="{Binding Error}" Width="200" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>

<Window x:Class="AlgowProforma.Views.BulkSendWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:m="clr-namespace:AlgowProforma.Models"
        Title="Toplu Teklif Gönderimi — Algow Proforma PDF"
        Width="1080" Height="760"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="{StaticResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal">
    <Window.Resources>
        <ObjectDataProvider x:Key="SalutationValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="m:Salutation" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Toplu Teklif Gönderimi" Style="{StaticResource DisplayText}" FontSize="22" FontWeight="Bold" />
            <TextBlock Text="Bir teklif seçin, alıcıları ekleyin; her alıcıya kendi adına PDF üretilip e-posta ile gönderilir." Style="{StaticResource MutedText}" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Teklif seçimi -->
        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Gönderilecek Teklif" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,12,0" />
            <ComboBox Grid.Column="1" Height="34" ItemsSource="{Binding SavedQuotes}" DisplayMemberPath="DisplayTitle" SelectedItem="{Binding SelectedQuote}" />
        </Grid>

        <!-- Alıcı ekleme -->
        <Grid Grid.Row="2" Margin="0,14,0,10">
            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBox Style="{StaticResource ModernTextBox}" Width="130" VerticalAlignment="Center" Margin="0,0,6,0"
                         Text="{Binding TagFilter, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Etiket süzgeci (örn: bayi) — CRM'den yüklerken yalnız bu etiketli müşteriler gelir; boş = hepsi" />
                <Button Style="{StaticResource SecondaryButton}" Content="CRM'den Yükle" Margin="0,0,8,0" Command="{Binding LoadFromCrmCommand}"
                        ToolTip="Müşteri listesinden alıcıları ekler; soldaki etiket süzgeci uygulanır" />
                <Button Style="{StaticResource SecondaryButton}" Content="Excel'den Al" Margin="0,0,8,0" Command="{Binding ImportExcelCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Content="Listeyi Temizle" Margin="0,0,16,0" Command="{Binding ClearRecipientsCommand}" />
            </StackPanel>
            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Style="{StaticResource ModernTextBox}" Text="{Binding ManualEmails, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="E-postaları virgül / boşluk / satırla ayırarak yapıştırın" />
                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="E-posta Ekle" Margin="8,0,0,0" Command="{Binding AddManualCommand}" />
            </Grid>
        </Grid>

        <!-- Önizleme listesi — alıcı ekleme yalnız üstteki kaynaklardan (hayalet satır yok) -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding Recipients}" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="" Binding="{Binding Selected}" Width="40" />
                <DataGridTextColumn Header="Firma" Binding="{Binding Company}" Width="*" />
                <DataGridTextColumn Header="Yetkili" Binding="{Binding ContactName}" Width="150" />
                <DataGridComboBoxColumn Header="Hitap" Width="80"
                                        SelectedItemBinding="{Binding Salutation}"
                                        ItemsSource="{Binding Source={StaticResource SalutationValues}}" />
                <DataGridTextColumn Header="E-posta" Binding="{Binding Email}" Width="220" />
                <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="160" IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="4" Margin="0,14,0,0">
            <TextBlock DockPanel.Dock="Left" Text="{Binding StatusText}" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" TextWrapping="Wrap" />
            <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Content="Önizle &amp; Gönder" Command="{Binding SendCommand}"
                    IsEnabled="{Binding IsNotBusy}" HorizontalAlignment="Right" />
            <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}" Content="İptal" Command="{Binding CancelSendCommand}"
                    IsEnabled="{Binding Busy}" Margin="0,0,8,0"
                    ToolTip="Süren gönderimi durdurur — sıradaki alıcıdan itibaren gönderilmez" />
        </DockPanel>
    </Grid>
</Window>
